---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const cutoff = new Date('2026-01-01');
const posts = (await getCollection('blog'))
	.filter((post) => post.data.pubDate >= cutoff)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="Insights on revenue systems, conversion architecture, and scaling digital businesses." />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-4xl px-6 py-16">
			<div class="mb-12">
				<p class="mb-2 font-mono text-sm tracking-widest text-accent uppercase">Insights</p>
				<h1 class="font-display text-3xl font-bold text-text md:text-4xl">Blog</h1>
			</div>
			{posts.length > 0 ? (
				<div class="grid gap-6 md:grid-cols-2">
					{posts.map((post, i) => (
						<a
							href={`/blog/${post.id}/`}
							class:list={[
								'group block rounded-xl border border-border bg-bg2 overflow-hidden transition-all duration-300 hover:border-accent/30 hover:bg-bg3 no-underline',
								i === 0 && 'md:col-span-2',
							]}
						>
							{post.data.heroImage && (
								<div class="overflow-hidden">
									<Image
										width={i === 0 ? 960 : 480}
										height={i === 0 ? 480 : 240}
										src={post.data.heroImage}
										alt=""
										class="w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
									/>
								</div>
							)}
							<div class="p-6">
								<p class="mb-2 font-mono text-xs text-muted-dark">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h2 class:list={[
									'font-semibold text-text group-hover:text-accent transition-colors',
									i === 0 ? 'text-2xl' : 'text-lg',
								]}>
									{post.data.title}
								</h2>
								{post.data.description && (
									<p class="mt-2 text-sm text-muted line-clamp-2">{post.data.description}</p>
								)}
							</div>
						</a>
					))}
				</div>
			) : (
				<div class="rounded-xl border border-border bg-bg2 p-16 text-center">
					<p class="font-mono text-sm tracking-widest text-accent uppercase">Coming Soon</p>
					<p class="mt-4 text-lg text-muted">Revenue Insights & Systems Thinking</p>
					<p class="mt-2 text-sm text-muted-dark">New articles on building revenue systems that compound.</p>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
