---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { brand } from '../../config/brand';

const product = brand.products.find(p => p.slug === "revenue-leak-audit-template")!;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Revenue Leak Audit Template | UHL Systems" description="The complete DIY audit framework. Excel + Notion template with pre-built formulas, ROI calculator, and video walkthrough. Our bestseller." />
		<style>
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(28px, 4vw, 44px);
				line-height: 1.15;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 16px 40px;
				font-weight: 600;
				font-size: 18px;
				transition: all 0.2s;
				display: inline-block;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.content-width {
				max-width: 820px;
				margin: 0 auto;
			}
			.feature-item {
				display: flex;
				align-items: flex-start;
				gap: 14px;
			}
			.feature-icon {
				flex-shrink: 0;
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				background: rgba(0, 255, 136, 0.1);
				color: var(--color-accent);
				margin-top: 2px;
			}
			.faq-item {
				border-bottom: 1px solid var(--color-border);
				padding: 24px 0;
			}
			.faq-item:last-child {
				border-bottom: none;
			}
		</style>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Who is this for?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "The Revenue Leak Audit Template is for business owners who want to run a professional-grade revenue audit on their own. Perfect for coaches, SaaS founders, and consultants who want the structure of a paid audit without the price tag."
					}
				},
				{
					"@type": "Question",
					"name": "What format is the template in?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "You get an Excel spreadsheet with pre-built formulas, a Notion workspace template, and a 20-minute video walkthrough showing you exactly how to use both."
					}
				},
				{
					"@type": "Question",
					"name": "Do I need prior knowledge?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "No. The video walkthrough guides you through every step. The templates are pre-built with formulas and frameworks - you just fill in your numbers and the system does the analysis."
					}
				}
			]
		}
		</script>
	</head>
	<body>
		<Header />

		<!-- Breadcrumb -->
		<div class="px-6 pt-28 pb-4">
			<div class="content-width">
				<nav class="flex items-center gap-2 font-mono text-sm text-muted-dark">
					<a href="/shop" class="transition-colors hover:text-accent">Shop</a>
					<span>&rarr;</span>
					<span class="text-muted">Revenue Leak Audit Template</span>
				</nav>
			</div>
		</div>

		<!-- Hero -->
		<section class="px-6 pb-20 pt-8">
			<div class="content-width">
				<div class="mb-6 flex flex-wrap items-center gap-3">
					<span class="inline-block rounded-full bg-accent/10 px-4 py-1.5 font-mono text-[11px] tracking-wider text-accent uppercase">Digital Download  - Instant Access</span>
					<span class="inline-block rounded-full bg-accent/15 px-4 py-1.5 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">Bestseller</span>
				</div>
				<h1 class="hero-headline fade-in font-display font-bold text-text">
					Revenue Leak Audit Template
				</h1>
				<p class="fade-in fade-in-delay-1 mt-6 max-w-2xl text-lg leading-relaxed text-muted">
					The complete DIY audit framework. Run a professional-grade revenue leak audit on your own business - with pre-built formulas that show you exactly where you're losing money.
				</p>
				<div class="fade-in fade-in-delay-2 mt-10 flex flex-wrap items-center gap-5">
					<div class="flex items-center gap-3">
						<span class="font-display text-4xl font-bold text-text">&euro;147</span>
						<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">Bestseller</span>
					</div>
				</div>
				<div class="fade-in fade-in-delay-3 mt-8">
					<a href={product.checkoutUrl} class="cta-primary block w-full text-center">Buy Now - {product.price}</a>
				</div>
			</div>
		</section>

		<!-- What You Get -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">What You Get</h2>
				<div class="grid gap-6 sm:grid-cols-2">
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Excel + Notion Template</p>
							<p class="mt-1 text-sm text-muted">Work in the tool you prefer - both are included</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Pre-built Formulas</p>
							<p class="mt-1 text-sm text-muted">Just enter your numbers - the template does the math</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">7-Station Analysis Framework</p>
							<p class="mt-1 text-sm text-muted">Audit every station of your revenue system</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">ROI Calculator</p>
							<p class="mt-1 text-sm text-muted">See exactly how much revenue you can recover</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Prioritization Matrix</p>
							<p class="mt-1 text-sm text-muted">Rank fixes by impact vs. effort - focus on what matters</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Video Walkthrough (20 min)</p>
							<p class="mt-1 text-sm text-muted">Watch exactly how to use the template step by step</p>
						</div>
					</div>
				</div>
				<p class="mt-8 font-mono text-sm text-muted-dark">Format: Excel + Notion + Video</p>
			</div>
		</section>

		<!-- Who This Is For -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Who This Is For</h2>
				<div class="grid gap-8 sm:grid-cols-3">
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Coaches</p>
						<p class="text-[15px] text-muted">You want to run a structured audit on your business without paying for a consultant - and get the same quality output.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">SaaS Founders</p>
						<p class="text-[15px] text-muted">You need a data-driven framework to find where users drop off and where revenue gets stuck in your system.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Consultants</p>
						<p class="text-[15px] text-muted">You want to offer revenue audits to your own clients using a proven, professional-grade template.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- What Problem It Solves -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">What Problem It Solves</h2>
				<div class="space-y-6 text-[16px] leading-relaxed text-muted">
					<p>
						You know you're leaving money on the table - but you don't have a systematic way to find out how much or where. Gut feelings and random optimization don't work. You need a framework that looks at every stage of your revenue system, quantifies the leaks, and tells you which fixes will have the highest ROI.
					</p>
					<p>
						The Revenue Leak Audit Template is that framework. It walks you through 7 stations of your revenue system - from traffic acquisition to lifetime value - with pre-built formulas that calculate your leak size at each stage. The built-in ROI calculator shows you how much revenue you can recover, and the prioritization matrix tells you exactly where to start.
					</p>
					<p>
						This is the same framework we use in our 2.5k+ client audits. The difference? You run it yourself, at your own pace, for a fraction of the cost. The 20-minute video walkthrough ensures you get the same quality results.
					</p>
				</div>
			</div>
		</section>

		<!-- Sample / Preview -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Here's What's Inside</h2>
				<div class="rounded-xl border border-border bg-bg2 p-8">
					<ul class="space-y-4 text-[15px] text-muted">
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>7-Station Revenue Audit - from Traffic to LTV, each station gets its own analysis tab</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Auto-Calculated Leak Scores - enter your numbers and the template highlights your biggest leaks</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>ROI Projection Dashboard - see how much revenue you'd recover by fixing each leak</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>20-Minute Video Walkthrough - watch exactly how to fill in the template and interpret results</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Frequently Asked Questions</h2>
				<div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Who is this for?</h3>
						<p class="text-[15px] text-muted">The Revenue Leak Audit Template is for business owners who want to run a professional-grade revenue audit on their own. Perfect for coaches, SaaS founders, and consultants who want the structure of a paid audit without the price tag.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">What format is the template in?</h3>
						<p class="text-[15px] text-muted">You get an Excel spreadsheet with pre-built formulas, a Notion workspace template, and a 20-minute video walkthrough showing you exactly how to use both.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Do I need prior knowledge?</h3>
						<p class="text-[15px] text-muted">No. The video walkthrough guides you through every step. The templates are pre-built with formulas and frameworks - you just fill in your numbers and the system does the analysis.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Bottom -->
		<section class="border-t border-border px-6 py-24">
			<div class="content-width text-center">
				<div class="flex items-center justify-center gap-3 mb-6">
					<span class="font-display text-4xl font-bold text-text">&euro;147</span>
					<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">Bestseller</span>
				</div>
				<a href={product.checkoutUrl} class="cta-primary block w-full text-center">Buy Now - {product.price}</a>
				</div>
		</section>




	<!-- Upsell -->
	<section class="border-t border-border px-6 py-16 bg-bg2">
		<div class="mx-auto max-w-3xl text-center">
			<p class="font-mono text-xs tracking-widest text-accent uppercase mb-3">Next Step</p>
			<h3 class="font-display text-xl font-bold text-text mb-3">
				Want the full picture?
			</h3>
			<p class="text-muted text-sm mb-6 max-w-md mx-auto">
				The Strategy Call takes your Revenue Leak Map and turns it into a prioritized action plan - specific to your business.
			</p>
			<a href={brand.strategyCall.checkoutUrl} class="cta-primary inline-flex items-center gap-2">
				Book Strategy Call - 97€
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
			<p class="mt-2 font-mono text-xs text-muted-dark">30 Min &nbsp;|&nbsp; 97€ &nbsp;|&nbsp; Payment at booking</p>
		</div>
	</section>

		<Footer />
	</body>
</html>
