---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { brand } from '../../config/brand';

const product = brand.products.find(p => p.slug === "revenue-leak-map-guide")!;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Revenue Leak Map PDF Guide | UHL Systems" description="30-page deep dive covering all 7 revenue leak types. Symptoms, diagnosis framework, and fix playbook for each - with real business examples." />
		<style>
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(28px, 4vw, 44px);
				line-height: 1.15;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 16px 40px;
				font-weight: 600;
				font-size: 18px;
				transition: all 0.2s;
				display: inline-block;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.content-width {
				max-width: 820px;
				margin: 0 auto;
			}
			.feature-item {
				display: flex;
				align-items: flex-start;
				gap: 14px;
			}
			.feature-icon {
				flex-shrink: 0;
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				background: rgba(0, 255, 136, 0.1);
				color: var(--color-accent);
				margin-top: 2px;
			}
			.faq-item {
				border-bottom: 1px solid var(--color-border);
				padding: 24px 0;
			}
			.faq-item:last-child {
				border-bottom: none;
			}
		</style>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Who is this for?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "The Revenue Leak Map is for online business owners who want to understand why revenue isn't growing as fast as it should. Ideal for coaches, SaaS founders, and consultants doing 5k-100k/month who suspect there are leaks but can't see them."
					}
				},
				{
					"@type": "Question",
					"name": "What format is the guide in?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "It's a 30-page PDF designed for both reading and reference. Each leak type gets its own chapter with symptoms, diagnosis steps, and a fix playbook."
					}
				},
				{
					"@type": "Question",
					"name": "Do I need prior knowledge?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "No. The guide explains each revenue leak type from scratch with real examples. If you run an online business and understand your basic metrics (traffic, conversion, revenue), you're ready."
					}
				}
			]
		}
		</script>
	</head>
	<body>
		<Header />

		<!-- Breadcrumb -->
		<div class="px-6 pt-28 pb-4">
			<div class="content-width">
				<nav class="flex items-center gap-2 font-mono text-sm text-muted-dark">
					<a href="/shop" class="transition-colors hover:text-accent">Shop</a>
					<span>&rarr;</span>
					<span class="text-muted">Revenue Leak Map PDF Guide</span>
				</nav>
			</div>
		</div>

		<!-- Hero -->
		<section class="px-6 pb-20 pt-8">
			<div class="content-width">
				<span class="mb-6 inline-block rounded-full bg-accent/10 px-4 py-1.5 font-mono text-[11px] tracking-wider text-accent uppercase">Digital Download  - Instant Access</span>
				<h1 class="hero-headline fade-in font-display font-bold text-text">
					Revenue Leak Map PDF Guide
				</h1>
				<p class="fade-in fade-in-delay-1 mt-6 max-w-2xl text-lg leading-relaxed text-muted">
					The complete map of all 7 revenue leak types - symptoms, diagnosis, and the exact fix for each. 30 pages of concentrated strategy.
				</p>
				<div class="fade-in fade-in-delay-2 mt-10 flex flex-wrap items-center gap-5">
					<span class="font-display text-4xl font-bold text-text">&euro;97</span>
				</div>
				<div class="fade-in fade-in-delay-3 mt-8">
					<a href={product.checkoutUrl} class="cta-primary block w-full text-center">Buy Now - {product.price}</a>
				</div>
			</div>
		</section>

		<!-- What You Get -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">What You Get</h2>
				<div class="grid gap-6 sm:grid-cols-2">
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">30-Page Deep Dive</p>
							<p class="mt-1 text-sm text-muted">Comprehensive guide - no fluff, all substance</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">All 7 Revenue Leak Types Explained</p>
							<p class="mt-1 text-sm text-muted">Every leak category mapped and broken down</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Symptom Checklist per Leak</p>
							<p class="mt-1 text-sm text-muted">Quickly identify which leaks apply to you</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Diagnosis Framework</p>
							<p class="mt-1 text-sm text-muted">Step-by-step process to confirm each leak</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Fix Playbook per Leak</p>
							<p class="mt-1 text-sm text-muted">Actionable fix strategy for each leak type</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Real Business Examples</p>
							<p class="mt-1 text-sm text-muted">See how each leak shows up in actual businesses</p>
						</div>
					</div>
				</div>
				<p class="mt-8 font-mono text-sm text-muted-dark">Format: PDF</p>
			</div>
		</section>

		<!-- Who This Is For -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Who This Is For</h2>
				<div class="grid gap-8 sm:grid-cols-3">
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Coaches</p>
						<p class="text-[15px] text-muted">You're generating leads but your revenue feels capped and you can't figure out why growth has stalled.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">SaaS Founders</p>
						<p class="text-[15px] text-muted">Your MRR isn't growing proportionally to your traffic - there are hidden leaks between signup and payment.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Consultants</p>
						<p class="text-[15px] text-muted">You want a complete mental model of revenue leaks so you can diagnose problems faster - for yourself or your clients.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- What Problem It Solves -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">What Problem It Solves</h2>
				<div class="space-y-6 text-[16px] leading-relaxed text-muted">
					<p>
						Revenue leaks are invisible by design. They don't show up as errors - they show up as stagnation. You're spending on ads, creating content, launching offers… but your revenue curve stays flat. The issue isn't effort. It's that you're optimizing the wrong things because you can't see where the actual leaks are.
					</p>
					<p>
						The Revenue Leak Map gives you a complete taxonomy of how online businesses lose money. Each of the 7 leak types has its own chapter: what it looks like, how to diagnose it, and exactly how to fix it. This isn't theory - it's the same framework we've used to recover six figures in lost revenue for clients.
					</p>
					<p>
						Once you can see the leaks, you can prioritize. Instead of running another A/B test or launching another campaign, you'll know which single fix will move the needle most. That clarity is worth more than any tactic.
					</p>
				</div>
			</div>
		</section>

		<!-- Sample / Preview -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Here's What's Inside</h2>
				<div class="rounded-xl border border-border bg-bg2 p-8">
					<ul class="space-y-4 text-[15px] text-muted">
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>The 7 Revenue Leak Types - a complete taxonomy from Traffic Leaks to Lifetime Value Leaks</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Symptom Checklists - 5-8 warning signs per leak type so you can self-diagnose in minutes</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Fix Playbooks - step-by-step repair guides with priority actions for each leak</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Real Examples - how each leak type showed up (and got fixed) in actual online businesses</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Frequently Asked Questions</h2>
				<div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Who is this for?</h3>
						<p class="text-[15px] text-muted">The Revenue Leak Map is for online business owners who want to understand why revenue isn't growing as fast as it should. Ideal for coaches, SaaS founders, and consultants doing 5k-100k/month who suspect there are leaks but can't see them.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">What format is the guide in?</h3>
						<p class="text-[15px] text-muted">It's a 30-page PDF designed for both reading and reference. Each leak type gets its own chapter with symptoms, diagnosis steps, and a fix playbook.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Do I need prior knowledge?</h3>
						<p class="text-[15px] text-muted">No. The guide explains each revenue leak type from scratch with real examples. If you run an online business and understand your basic metrics (traffic, conversion, revenue), you're ready.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Bottom -->
		<section class="border-t border-border px-6 py-24">
			<div class="content-width text-center">
				<div class="mb-6">
					<span class="font-display text-4xl font-bold text-text">&euro;97</span>
				</div>
				<a href={product.checkoutUrl} class="cta-primary block w-full text-center">Buy Now - {product.price}</a>
				</div>
		</section>




	<!-- Upsell -->
	<section class="border-t border-border px-6 py-16 bg-bg2">
		<div class="mx-auto max-w-3xl text-center">
			<p class="font-mono text-xs tracking-widest text-accent uppercase mb-3">Next Step</p>
			<h3 class="font-display text-xl font-bold text-text mb-3">
				Want the full picture?
			</h3>
			<p class="text-muted text-sm mb-6 max-w-md mx-auto">
				The Strategy Call takes your Revenue Leak Map and turns it into a prioritized action plan - specific to your business.
			</p>
			<a href={brand.strategyCall.checkoutUrl} class="cta-primary inline-flex items-center gap-2">
				Book Strategy Call - 97€
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
			<p class="mt-2 font-mono text-xs text-muted-dark">30 Min &nbsp;|&nbsp; 97€ &nbsp;|&nbsp; Payment at booking</p>
		</div>
	</section>

		<Footer />
	</body>
</html>
