---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="90-Day Revenue System Playbook | UHL Systems" description="Week-by-week execution plan to build a complete revenue system from scratch. 13 weeks of daily action items, KPI tracking, and milestone checklists." />
		<style>
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(28px, 4vw, 44px);
				line-height: 1.15;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 16px 40px;
				font-weight: 600;
				font-size: 18px;
				transition: all 0.2s;
				display: inline-block;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.content-width {
				max-width: 820px;
				margin: 0 auto;
			}
			.feature-item {
				display: flex;
				align-items: flex-start;
				gap: 14px;
			}
			.feature-icon {
				flex-shrink: 0;
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				background: rgba(0, 255, 136, 0.1);
				color: var(--color-accent);
				margin-top: 2px;
			}
			.faq-item {
				border-bottom: 1px solid var(--color-border);
				padding: 24px 0;
			}
			.faq-item:last-child {
				border-bottom: none;
			}
		</style>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Who is this for?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "The 90-Day Playbook is for business owners who are done with random tactics and want a structured system. Ideal for coaches, SaaS founders, and consultants who want to build a revenue system from Traffic to LTV in 13 weeks."
					}
				},
				{
					"@type": "Question",
					"name": "What format is the playbook in?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "You get a comprehensive PDF with the full 13-week plan plus Google Sheets templates for KPI tracking, milestone checklists, and client communication."
					}
				},
				{
					"@type": "Question",
					"name": "Do I need prior knowledge?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "No. The playbook starts from scratch and walks you through each week. Every action item is specific and explained. If you can follow a recipe, you can follow this playbook."
					}
				}
			]
		}
		</script>
	</head>
	<body>
		<Header />

		<!-- Breadcrumb -->
		<div class="px-6 pt-28 pb-4">
			<div class="content-width">
				<nav class="flex items-center gap-2 font-mono text-sm text-muted-dark">
					<a href="/shop" class="transition-colors hover:text-accent">Shop</a>
					<span>&rarr;</span>
					<span class="text-muted">90-Day Revenue System Playbook</span>
				</nav>
			</div>
		</div>

		<!-- Hero -->
		<section class="px-6 pb-20 pt-8">
			<div class="content-width">
				<span class="mb-6 inline-block rounded-full bg-accent/10 px-4 py-1.5 font-mono text-[11px] tracking-wider text-accent uppercase">Digital Download &mdash; Instant Access</span>
				<h1 class="hero-headline fade-in font-display font-bold text-text">
					90-Day Revenue System Playbook
				</h1>
				<p class="fade-in fade-in-delay-1 mt-6 max-w-2xl text-lg leading-relaxed text-muted">
					Build a complete revenue system from scratch in 13 weeks. Daily action items, weekly milestones, and KPI tracking — from traffic to lifetime value.
				</p>
				<div class="fade-in fade-in-delay-2 mt-10 flex flex-wrap items-center gap-5">
					<span class="font-display text-4xl font-bold text-text">&euro;197</span>
				</div>
				<div class="fade-in fade-in-delay-3 mt-8">
					<a href="https://shop.uhl-systems.com/checkout/buy/531a2a29-8a07-484a-9ef6-84798405b20e" class="cta-primary">
						Get Instant Access &rarr;
					</a>
				</div>
			</div>
		</section>

		<!-- What You Get -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">What You Get</h2>
				<div class="grid gap-6 sm:grid-cols-2">
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Week-by-Week Execution Plan</p>
							<p class="mt-1 text-sm text-muted">13 weeks mapped out — every week has a clear focus</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Daily Action Items</p>
							<p class="mt-1 text-sm text-muted">Know exactly what to do every single day</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">KPI Tracking Templates</p>
							<p class="mt-1 text-sm text-muted">Measure progress with pre-built tracking sheets</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Traffic &rarr; LTV Full System Build</p>
							<p class="mt-1 text-sm text-muted">End-to-end revenue system, not just tactics</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Milestone Checklists</p>
							<p class="mt-1 text-sm text-muted">Clear checkpoints so you know you're on track</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Email Templates for Client Communication</p>
							<p class="mt-1 text-sm text-muted">Ready-to-send templates for every stage</p>
						</div>
					</div>
				</div>
				<p class="mt-8 font-mono text-sm text-muted-dark">Format: PDF + Google Sheets</p>
			</div>
		</section>

		<!-- Who This Is For -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Who This Is For</h2>
				<div class="grid gap-8 sm:grid-cols-3">
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Coaches</p>
						<p class="text-[15px] text-muted">You've been winging it with random marketing tactics and want a structured system that compounds over 90 days.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">SaaS Founders</p>
						<p class="text-[15px] text-muted">You need to build a predictable revenue engine — not just ship features — and want a proven playbook to follow.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Consultants</p>
						<p class="text-[15px] text-muted">You want a turnkey system you can implement for yourself or adapt for your clients' businesses.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- What Problem It Solves -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">What Problem It Solves</h2>
				<div class="space-y-6 text-[16px] leading-relaxed text-muted">
					<p>
						You know you need a revenue system. But every time you sit down to build one, you get stuck: What comes first? How do the pieces connect? Am I working on the right thing this week? Without a blueprint, you end up jumping between tactics — this week it's email sequences, next week it's ads, then it's a new landing page. Nothing compounds.
					</p>
					<p>
						The 90-Day Revenue System Playbook eliminates this chaos. It gives you a week-by-week execution plan that builds your entire revenue system in the right order — from traffic acquisition to conversion optimization to lifetime value maximization. Each week builds on the last, and every daily action item has a clear purpose.
					</p>
					<p>
						By Day 90, you don't just have a collection of tactics. You have a system: traffic flowing in, leads converting, customers retained, and revenue growing predictably. The KPI tracking templates show you exactly where you stand at every milestone, so you never lose sight of the bigger picture.
					</p>
				</div>
			</div>
		</section>

		<!-- Sample / Preview -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Here's What's Inside</h2>
				<div class="rounded-xl border border-border bg-bg2 p-8">
					<ul class="space-y-4 text-[15px] text-muted">
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Weeks 1-4: Foundation — traffic audit, funnel mapping, conversion baseline, and quick wins</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Weeks 5-8: Build — email sequences, retargeting setup, offer optimization, and upsell system</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Weeks 9-13: Scale — LTV maximization, referral engine, KPI dashboard, and system automation</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Bonus: 15+ email templates for client communication at every stage of the revenue cycle</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Frequently Asked Questions</h2>
				<div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Who is this for?</h3>
						<p class="text-[15px] text-muted">The 90-Day Playbook is for business owners who are done with random tactics and want a structured system. Ideal for coaches, SaaS founders, and consultants who want to build a revenue system from Traffic to LTV in 13 weeks.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">What format is the playbook in?</h3>
						<p class="text-[15px] text-muted">You get a comprehensive PDF with the full 13-week plan plus Google Sheets templates for KPI tracking, milestone checklists, and client communication.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Do I need prior knowledge?</h3>
						<p class="text-[15px] text-muted">No. The playbook starts from scratch and walks you through each week. Every action item is specific and explained. If you can follow a recipe, you can follow this playbook.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Bottom -->
		<section class="border-t border-border px-6 py-24">
			<div class="content-width text-center">
				<div class="mb-6">
					<span class="font-display text-4xl font-bold text-text">&euro;197</span>
				</div>
				<a href="https://shop.uhl-systems.com/checkout/buy/531a2a29-8a07-484a-9ef6-84798405b20e" class="cta-primary text-lg">
					Get Instant Access &rarr;
				</a>
				</div>
		</section>

		<Footer />
	</body>
</html>
