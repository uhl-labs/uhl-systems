---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Shop — Digital Products | UHL Systems" description="Revenue frameworks, templates, and playbooks you can use today. Built from the same methodology we use with clients." />
		<style>
			.section-heading {
				font-size: clamp(32px, 5vw, 56px);
				line-height: 1.1;
				letter-spacing: -0.02em;
			}
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 14px 36px;
				font-weight: 600;
				transition: all 0.2s;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.cta-ghost {
				border: 1px solid var(--color-border);
				border-radius: 999px;
				padding: 14px 36px;
				color: var(--color-muted);
				transition: all 0.2s;
			}
			.cta-ghost:hover {
				border-color: var(--color-accent);
				color: var(--color-text);
			}
			.product-card {
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 40px 32px;
				transition: all 0.3s;
				display: flex;
				flex-direction: column;
			}
			.product-card:hover {
				border-color: rgba(0, 255, 136, 0.25);
				background: var(--color-bg3);
			}
			.content-width {
				max-width: 1100px;
				margin: 0 auto;
			}
			.prose-width {
				max-width: 720px;
				margin: 0 auto;
			}
		</style>
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="relative overflow-hidden px-6 py-24 md:py-36">
			<div class="content-width text-center">
				<p class="fade-in mb-6 font-mono text-sm tracking-widest text-accent uppercase">Digital Products</p>
				<h1 class="hero-headline fade-in fade-in-delay-1 font-display font-bold text-text">
					Revenue Tools You Can Use Today
				</h1>
				<p class="fade-in fade-in-delay-2 mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-muted">
					Built from the same frameworks we use with clients. Templates, guides, and playbooks to find and fix your revenue leaks — on your own terms.
				</p>
			</div>
			<!-- Background grid effect -->
			<div class="pointer-events-none absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0); background-size: 40px 40px;"></div>
			<div class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full" style="background: radial-gradient(circle, rgba(0,255,136,0.05) 0%, transparent 70%);"></div>
		</section>

		<!-- Products Grid -->
		<section class="border-t border-border px-6 py-28">
			<div class="content-width">
				<div class="grid gap-8 md:grid-cols-2">

					<!-- Product 1: Revenue Leak Audit Template -->
					<div class="product-card">
						<div class="mb-4 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
							</div>
							<div>
								<h2 class="text-xl font-semibold text-text">Revenue Leak Audit Template</h2>
								<p class="font-mono text-xs tracking-wider text-muted-dark uppercase">DIY Framework</p>
							</div>
						</div>
						<p class="mb-6 text-[15px] leading-relaxed text-muted">
							The complete DIY framework. Excel/Notion template to run your own Revenue Leak Audit. All 7 stations, pre-built formulas, and an evaluation guide to score every stage of your revenue pipeline.
						</p>
						<div class="mb-6 border-t border-border pt-6">
							<span class="font-display text-3xl font-bold text-text">&euro;47</span>
							<div class="mt-2 flex items-center gap-2">
								<span class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] tracking-wider text-accent uppercase">Digital Download &mdash; Instant Access</span>
							</div>
						</div>
						<div class="mt-auto space-y-3">
							<a href="mailto:luke@uhl-systems.com?subject=Order: Revenue Leak Audit Template" class="cta-primary block w-full text-center">
								Get the Template &rarr;
							</a>
							<p class="text-center font-mono text-[10px] tracking-wider text-muted-dark">Secure Payment via Stripe</p>
						</div>
					</div>

					<!-- Product 2: The Revenue Leak Map (PDF Guide) -->
					<div class="product-card">
						<div class="mb-4 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="m9 15 3-3 3 3"/></svg>
							</div>
							<div>
								<h2 class="text-xl font-semibold text-text">The Revenue Leak Map</h2>
								<p class="font-mono text-xs tracking-wider text-muted-dark uppercase">PDF Guide</p>
							</div>
						</div>
						<p class="mb-6 text-[15px] leading-relaxed text-muted">
							30-page guide covering all 7 Revenue Leaks — with symptoms, diagnosis, and fix for each leak. The ideal entry point to understand where your business is losing money and what to do about it.
						</p>
						<div class="mb-6 border-t border-border pt-6">
							<span class="font-display text-3xl font-bold text-text">&euro;27</span>
							<div class="mt-2 flex items-center gap-2">
								<span class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] tracking-wider text-accent uppercase">Digital Download &mdash; Instant Access</span>
							</div>
						</div>
						<div class="mt-auto space-y-3">
							<a href="mailto:luke@uhl-systems.com?subject=Order: The Revenue Leak Map (PDF Guide)" class="cta-primary block w-full text-center">
								Download the Guide &rarr;
							</a>
							<p class="text-center font-mono text-[10px] tracking-wider text-muted-dark">Secure Payment via Stripe</p>
						</div>
					</div>

					<!-- Product 3: 90-Day Revenue System Playbook -->
					<div class="product-card">
						<div class="mb-4 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
							</div>
							<div>
								<h2 class="text-xl font-semibold text-text">90-Day Revenue System Playbook</h2>
								<p class="font-mono text-xs tracking-wider text-muted-dark uppercase">Execution Plan</p>
							</div>
						</div>
						<p class="mb-6 text-[15px] leading-relaxed text-muted">
							The complete execution plan — week by week, what to do to build your revenue system. Designed for coaches, SaaS founders, and consultants who want a clear path from diagnosis to a compounding business.
						</p>
						<div class="mb-6 border-t border-border pt-6">
							<span class="font-display text-3xl font-bold text-text">&euro;97</span>
							<div class="mt-2 flex items-center gap-2">
								<span class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] tracking-wider text-accent uppercase">Digital Download &mdash; Instant Access</span>
							</div>
						</div>
						<div class="mt-auto space-y-3">
							<a href="mailto:luke@uhl-systems.com?subject=Order: 90-Day Revenue System Playbook" class="cta-primary block w-full text-center">
								Get the Playbook &rarr;
							</a>
							<p class="text-center font-mono text-[10px] tracking-wider text-muted-dark">Secure Payment via Stripe</p>
						</div>
					</div>

					<!-- Product 4: UHL Conversion Audit Checklist -->
					<div class="product-card">
						<div class="mb-4 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
							</div>
							<div>
								<h2 class="text-xl font-semibold text-text">UHL Conversion Audit Checklist</h2>
								<p class="font-mono text-xs tracking-wider text-muted-dark uppercase">50-Point Checklist</p>
							</div>
						</div>
						<p class="mb-6 text-[15px] leading-relaxed text-muted">
							50-point checklist to audit every step of your funnel. Actionable, immediately usable. Go through each checkpoint, identify the gaps, and start fixing them today.
						</p>
						<div class="mb-6 border-t border-border pt-6">
							<span class="font-display text-3xl font-bold text-text">&euro;17</span>
							<div class="mt-2 flex items-center gap-2">
								<span class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] tracking-wider text-accent uppercase">Digital Download &mdash; Instant Access</span>
							</div>
						</div>
						<div class="mt-auto space-y-3">
							<a href="mailto:luke@uhl-systems.com?subject=Order: UHL Conversion Audit Checklist" class="cta-primary block w-full text-center">
								Get the Checklist &rarr;
							</a>
							<p class="text-center font-mono text-[10px] tracking-wider text-muted-dark">Secure Payment via Stripe</p>
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- CTA to Services -->
		<section class="border-t border-border px-6 py-28">
			<div class="content-width text-center">
				<p class="mb-4 font-mono text-sm tracking-widest text-accent uppercase">Need More?</p>
				<h2 class="section-heading mb-6 font-display font-bold text-text">
					Want us to do it for you?
				</h2>
				<p class="mx-auto mb-14 max-w-xl text-muted">
					These tools are powerful on their own — but if you want hands-on help finding and fixing your revenue leaks, check out our services.
				</p>
				<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a href="/services/audit" class="cta-primary inline-flex items-center gap-2">
						Explore Services
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
					<a href="/#contact" class="cta-ghost inline-flex items-center gap-2">
						Contact Us
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
