---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { brand } from '../../config/brand';

const product = brand.products.find(p => p.slug === "conversion-audit-checklist")!;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Conversion Audit Checklist | UHL Systems" description="50-point checklist to audit every step of your funnel. Find your top 3 revenue leaks in under 60 minutes." />
		<style>
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(28px, 4vw, 44px);
				line-height: 1.15;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 16px 40px;
				font-weight: 600;
				font-size: 18px;
				transition: all 0.2s;
				display: inline-block;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.content-width {
				max-width: 820px;
				margin: 0 auto;
			}
			.feature-item {
				display: flex;
				align-items: flex-start;
				gap: 14px;
			}
			.feature-icon {
				flex-shrink: 0;
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				background: rgba(0, 255, 136, 0.1);
				color: var(--color-accent);
				margin-top: 2px;
			}
			.faq-item {
				border-bottom: 1px solid var(--color-border);
				padding: 24px 0;
			}
			.faq-item:last-child {
				border-bottom: none;
			}
		</style>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Who is this for?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "The Conversion Audit Checklist is built for coaches, SaaS founders, and consultants who have traffic but aren't converting it into revenue as well as they should. If you suspect your funnel has leaks but don't know where to start - this is for you."
					}
				},
				{
					"@type": "Question",
					"name": "What format is the checklist in?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "You get both a beautifully designed PDF and a Notion template so you can work through it digitally or print it out."
					}
				},
				{
					"@type": "Question",
					"name": "Do I need prior knowledge?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "No. The checklist is designed to be self-explanatory. Each point tells you exactly what to check and what a 'pass' or 'fail' looks like. No marketing degree required."
					}
				}
			]
		}
		</script>
	</head>
	<body>
		<Header />

		<!-- Breadcrumb -->
		<div class="px-6 pt-28 pb-4">
			<div class="content-width">
				<nav class="flex items-center gap-2 font-mono text-sm text-muted-dark">
					<a href="/shop" class="transition-colors hover:text-accent">Shop</a>
					<span>&rarr;</span>
					<span class="text-muted">Conversion Audit Checklist</span>
				</nav>
			</div>
		</div>

		<!-- Hero -->
		<section class="px-6 pb-20 pt-8">
			<div class="content-width">
				<span class="mb-6 inline-block rounded-full bg-accent/10 px-4 py-1.5 font-mono text-[11px] tracking-wider text-accent uppercase">Digital Download  - Instant Access</span>
				<h1 class="hero-headline fade-in font-display font-bold text-text">
					Conversion Audit Checklist
				</h1>
				<p class="fade-in fade-in-delay-1 mt-6 max-w-2xl text-lg leading-relaxed text-muted">
					Find your top 3 revenue leaks in under 60 minutes. 50 precise checkpoints across your entire funnel.
				</p>
				<div class="fade-in fade-in-delay-2 mt-10 flex flex-wrap items-center gap-5">
					<div class="flex items-center gap-3">
						<span class="font-display text-4xl font-bold text-text">&euro;47</span>
						<span class="text-xl text-muted-dark line-through">&euro;97</span>
						<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">50% OFF</span>
					</div>
				</div>
				<div class="fade-in fade-in-delay-3 mt-8">
					<button disabled class="cta-primary opacity-50 cursor-not-allowed w-full" style="pointer-events:none;">Coming Soon</button>
				</div>
			</div>
		</section>

		<!-- What You Get -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">What You Get</h2>
				<div class="grid gap-6 sm:grid-cols-2">
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">50-Point Checklist</p>
							<p class="mt-1 text-sm text-muted">Every critical conversion point covered</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Traffic Audit Section</p>
							<p class="mt-1 text-sm text-muted">Evaluate where your visitors come from and drop off</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Funnel Audit Section</p>
							<p class="mt-1 text-sm text-muted">Map and stress-test every step in your funnel</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Conversion Audit Section</p>
							<p class="mt-1 text-sm text-muted">Pinpoint exactly where conversions break</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Monetization Audit Section</p>
							<p class="mt-1 text-sm text-muted">Check pricing, upsells, and revenue per customer</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Scoring System</p>
							<p class="mt-1 text-sm text-muted">Identify your top 3 leaks instantly with built-in scoring</p>
						</div>
					</div>
				</div>
				<p class="mt-8 font-mono text-sm text-muted-dark">Format: PDF + Notion Template</p>
			</div>
		</section>

		<!-- Who This Is For -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Who This Is For</h2>
				<div class="grid gap-8 sm:grid-cols-3">
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Coaches</p>
						<p class="text-[15px] text-muted">You have a proven offer but your funnel isn't converting the traffic you're paying for.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">SaaS Founders</p>
						<p class="text-[15px] text-muted">Your trial-to-paid conversion is lower than it should be and you can't pinpoint why.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Consultants</p>
						<p class="text-[15px] text-muted">You want a structured framework to audit your own pipeline before hiring an agency.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- What Problem It Solves -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">What Problem It Solves</h2>
				<div class="space-y-6 text-[16px] leading-relaxed text-muted">
					<p>
						Most businesses lose 20-40% of potential revenue to invisible funnel leaks. The problem isn't traffic - it's what happens after someone clicks. A broken checkout flow, unclear value proposition, or missing follow-up sequence can silently drain thousands per month.
					</p>
					<p>
						The Conversion Audit Checklist gives you a systematic way to walk through every step of your funnel and score each one. Instead of guessing what's broken, you get a clear ranking of your biggest leaks - so you know exactly where to focus first.
					</p>
					<p>
						Built from the same methodology we use in our 2.5k+ client audits, distilled into a self-serve format. You don't need analytics expertise or expensive tools. Just honest answers and 60 minutes.
					</p>
				</div>
			</div>
		</section>

		<!-- Sample / Preview -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Here's What's Inside</h2>
				<div class="rounded-xl border border-border bg-bg2 p-8">
					<ul class="space-y-4 text-[15px] text-muted">
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Traffic Quality Matrix - score each traffic source by intent, volume, and cost</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Landing Page Conversion Checklist - 12 specific elements that make or break your first impression</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Checkout Flow Audit - 8 friction points most businesses miss entirely</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Revenue Leak Scoring Sheet - auto-ranks your top 3 leaks by estimated revenue impact</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Frequently Asked Questions</h2>
				<div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Who is this for?</h3>
						<p class="text-[15px] text-muted">The Conversion Audit Checklist is built for coaches, SaaS founders, and consultants who have traffic but aren't converting it into revenue as well as they should. If you suspect your funnel has leaks but don't know where to start - this is for you.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">What format is the checklist in?</h3>
						<p class="text-[15px] text-muted">You get both a beautifully designed PDF and a Notion template so you can work through it digitally or print it out.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Do I need prior knowledge?</h3>
						<p class="text-[15px] text-muted">No. The checklist is designed to be self-explanatory. Each point tells you exactly what to check and what a "pass" or "fail" looks like. No marketing degree required.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Bottom -->
		<section class="border-t border-border px-6 py-24">
			<div class="content-width text-center">
				<div class="flex items-center justify-center gap-3 mb-6">
					<span class="font-display text-4xl font-bold text-text">&euro;47</span>
					<span class="text-xl text-muted-dark line-through">&euro;97</span>
					<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">50% OFF</span>
				</div>
				<button disabled class="cta-primary opacity-50 cursor-not-allowed w-full" style="pointer-events:none;">Coming Soon</button>
				</div>
		</section>

		<Footer />
	</body>
</html>
