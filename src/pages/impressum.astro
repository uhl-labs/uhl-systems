---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Legal Notice | UHL Systems" description="Legal Notice – Information pursuant to § 5 TMG" />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-3xl px-6 py-24">
			<h1 class="mb-12 font-display text-3xl font-bold tracking-tight text-text">Legal Notice (Impressum)</h1>

			<div class="space-y-8 text-muted">
				<section>
					<p class="mb-1 text-sm uppercase tracking-widest text-muted-dark">Information pursuant to § 5 TMG</p>
					<p class="text-text">Lukas Uhl</p>
					<p>UHL Labs</p>
					<p>Enthofstraße 1</p>
					<p>85276 Pfaffenhofen, Germany</p>
				</section>

				<section>
					<p class="mb-1 text-sm uppercase tracking-widest text-muted-dark">Contact</p>
					<p>Email: <a href="mailto:luke@uhl-systems.com" class="text-accent transition-colors hover:text-accent2">luke@uhl-systems.com</a></p>
					<p>Web: <a href="https://www.uhl-systems.com" class="text-accent transition-colors hover:text-accent2">www.uhl-systems.com</a></p>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
