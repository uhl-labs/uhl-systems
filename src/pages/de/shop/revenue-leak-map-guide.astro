---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title="Revenue Leak Map PDF Guide | UHL Systems" description="30-seitiger Deep Dive zu allen 7 Revenue-Leak-Typen. Symptome, Diagnose-Framework und Loesung fuer jeden einzelnen - mit echten Business-Beispielen." />
		<style>
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(28px, 4vw, 44px);
				line-height: 1.15;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 16px 40px;
				font-weight: 600;
				font-size: 18px;
				transition: all 0.2s;
				display: inline-block;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.content-width {
				max-width: 820px;
				margin: 0 auto;
			}
			.feature-item {
				display: flex;
				align-items: flex-start;
				gap: 14px;
			}
			.feature-icon {
				flex-shrink: 0;
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				background: rgba(0, 255, 136, 0.1);
				color: var(--color-accent);
				margin-top: 2px;
			}
			.faq-item {
				border-bottom: 1px solid var(--color-border);
				padding: 24px 0;
			}
			.faq-item:last-child {
				border-bottom: none;
			}
		</style>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Fuer wen ist das?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Die Revenue Leak Map ist fuer Online-Business-Inhaber, die verstehen wollen, warum ihr Umsatz nicht so schnell waechst wie er sollte. Ideal fuer Coaches, SaaS-Gruender und Berater mit 5k-100k/Monat, die Leaks vermuten, aber nicht sehen koennen."
					}
				},
				{
					"@type": "Question",
					"name": "In welchem Format ist der Guide?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Es ist ein 30-seitiges PDF, das sowohl zum Lesen als auch als Nachschlagewerk konzipiert ist. Jeder Leak-Typ bekommt sein eigenes Kapitel mit Symptomen, Diagnose-Schritten und einem Fix-Playbook."
					}
				},
				{
					"@type": "Question",
					"name": "Brauche ich Vorkenntnisse?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Nein. Der Guide erklaert jeden Revenue-Leak-Typ von Grund auf mit echten Beispielen. Wenn du ein Online-Business fuehrst und deine Basis-Metriken kennst (Traffic, Conversion, Umsatz), bist du bereit."
					}
				}
			]
		}
		</script>
	</head>
	<body>
