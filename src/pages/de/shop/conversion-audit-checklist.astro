---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { brand } from '../../../config/brand';

const product = brand.products.find(p => p.slug === "conversion-audit-checklist")!;
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title="Conversion Audit Checkliste | UHL Systems" description="50-Punkte-Checkliste, um jeden Schritt deines Funnels zu pruefen. Finde deine Top-3 Revenue Leaks in unter 60 Minuten." />
		<style>
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(28px, 4vw, 44px);
				line-height: 1.15;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 16px 40px;
				font-weight: 600;
				font-size: 18px;
				transition: all 0.2s;
				display: inline-block;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.content-width {
				max-width: 820px;
				margin: 0 auto;
			}
			.feature-item {
				display: flex;
				align-items: flex-start;
				gap: 14px;
			}
			.feature-icon {
				flex-shrink: 0;
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				background: rgba(0, 255, 136, 0.1);
				color: var(--color-accent);
				margin-top: 2px;
			}
			.faq-item {
				border-bottom: 1px solid var(--color-border);
				padding: 24px 0;
			}
			.faq-item:last-child {
				border-bottom: none;
			}
		</style>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Fuer wen ist das?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Die Conversion Audit Checkliste ist fuer Coaches, SaaS-Gruender und Berater, die Traffic haben, ihn aber nicht so gut in Umsatz umwandeln wie sie sollten. Wenn du vermutest, dass dein Funnel Leaks hat, aber nicht weisst, wo du anfangen sollst - das ist fuer dich."
					}
				},
				{
					"@type": "Question",
					"name": "In welchem Format ist die Checkliste?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Du bekommst sowohl ein schoen gestaltetes PDF als auch ein Notion Template, sodass du digital oder ausgedruckt damit arbeiten kannst."
					}
				},
				{
					"@type": "Question",
					"name": "Brauche ich Vorkenntnisse?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Nein. Die Checkliste ist selbsterklaerend gestaltet. Jeder Punkt sagt dir genau, was du pruefen sollst und wie 'bestanden' oder 'durchgefallen' aussieht. Kein Marketing-Studium noetig."
					}
				}
			]
		}
		</script>
	</head>
	<body>
		<Header />

		<!-- Breadcrumb -->
		<div class="px-6 pt-28 pb-4">
			<div class="content-width">
				<nav class="flex items-center gap-2 font-mono text-sm text-muted-dark">
					<a href="/de/shop" class="transition-colors hover:text-accent">Shop</a>
					<span>&rarr;</span>
					<span class="text-muted">Conversion Audit Checkliste</span>
				</nav>
			</div>
		</div>

		<!-- Hero -->
		<section class="px-6 pb-20 pt-8">
			<div class="content-width">
				<span class="mb-6 inline-block rounded-full bg-accent/10 px-4 py-1.5 font-mono text-[11px] tracking-wider text-accent uppercase">Digitaler Download - Sofort-Zugang</span>
				<h1 class="hero-headline fade-in font-display font-bold text-text">
					Conversion Audit Checkliste
				</h1>
				<p class="fade-in fade-in-delay-1 mt-6 max-w-2xl text-lg leading-relaxed text-muted">
					Finde deine Top-3 Revenue Leaks in unter 60 Minuten. 50 praezise Checkpoints ueber deinen gesamten Funnel.
				</p>
				<div class="fade-in fade-in-delay-2 mt-10 flex flex-wrap items-center gap-5">
					<div class="flex items-center gap-3">
						<span class="font-display text-4xl font-bold text-text">&euro;47</span>
						<span class="text-xl text-muted-dark line-through">&euro;97</span>
						<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">50% RABATT</span>
					</div>
				</div>
				<div class="fade-in fade-in-delay-3 mt-8">
					<button disabled class="cta-primary opacity-50 cursor-not-allowed w-full" style="pointer-events:none;">Coming Soon</button>
				</div>
			</div>
		</section>

		<!-- What You Get -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Was du bekommst</h2>
				<div class="grid gap-6 sm:grid-cols-2">
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">50-Punkte-Checkliste</p>
							<p class="mt-1 text-sm text-muted">Jeder kritische Conversion-Punkt abgedeckt</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Traffic-Audit-Sektion</p>
							<p class="mt-1 text-sm text-muted">Bewerte, woher deine Besucher kommen und wo sie abspringen</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Funnel-Audit-Sektion</p>
							<p class="mt-1 text-sm text-muted">Jeden Schritt deines Funnels kartieren und stresstesten</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Conversion-Audit-Sektion</p>
							<p class="mt-1 text-sm text-muted">Genau erkennen, wo Conversions scheitern</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Monetarisierungs-Audit-Sektion</p>
							<p class="mt-1 text-sm text-muted">Pricing, Upsells und Umsatz pro Kunde pruefen</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Bewertungssystem</p>
							<p class="mt-1 text-sm text-muted">Deine Top-3 Leaks sofort identifizieren mit eingebautem Scoring</p>
						</div>
					</div>
				</div>
				<p class="mt-8 font-mono text-sm text-muted-dark">Format: PDF + Notion Template</p>
			</div>
		</section>

		<!-- Who This Is For -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Fuer wen ist das</h2>
				<div class="grid gap-8 sm:grid-cols-3">
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Coaches</p>
						<p class="text-[15px] text-muted">Du hast ein bewaehrtes Angebot, aber dein Funnel konvertiert den Traffic nicht, fuer den du bezahlst.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">SaaS-Gruender</p>
						<p class="text-[15px] text-muted">Deine Trial-zu-Paid-Conversion ist niedriger als sie sein sollte und du kannst nicht genau sagen, warum.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Berater</p>
						<p class="text-[15px] text-muted">Du willst deine eigene Pipeline durchleuchten, bevor du Geld fuer eine Agentur ausgibst.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- What Problem It Solves -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Welches Problem es loest</h2>
				<div class="space-y-6 text-[16px] leading-relaxed text-muted">
					<p>
						Die meisten Unternehmen verlieren 20-40% ihres potenziellen Umsatzes durch unsichtbare Funnel-Leaks. Das Problem ist nicht der Traffic - es ist, was passiert, nachdem jemand klickt. Ein kaputter Checkout-Flow, eine unklare Value Proposition oder eine fehlende Follow-up-Sequenz kann still und leise Tausende pro Monat kosten.
					</p>
					<p>
						Die Conversion Audit Checkliste gibt dir einen systematischen Weg, jeden Schritt deines Funnels durchzugehen und zu bewerten. Anstatt zu raten, was kaputt ist, bekommst du ein klares Ranking deiner groessten Leaks - damit du genau weisst, wo du zuerst ansetzen musst.
					</p>
					<p>
						Basierend auf derselben Methodik, die wir in unseren 2.5k+ Kunden-Audits verwenden, destilliert in ein Selbstbedienungs-Format. Du brauchst keine Analytics-Expertise oder teure Tools. Nur ehrliche Antworten und 60 Minuten.
					</p>
				</div>
			</div>
		</section>

		<!-- Sample / Preview -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Das steckt drin</h2>
				<div class="rounded-xl border border-border bg-bg2 p-8">
					<ul class="space-y-4 text-[15px] text-muted">
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Traffic-Qualitaetsmatrix - jede Traffic-Quelle nach Intent, Volumen und Kosten bewerten</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Landing Page Conversion Checkliste - 12 spezifische Elemente, die deinen ersten Eindruck machen oder brechen</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Checkout-Flow-Audit - 8 Reibungspunkte, die die meisten Unternehmen komplett uebersehen</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Revenue Leak Scoring Sheet - rankt automatisch deine Top-3 Leaks nach geschaetztem Umsatz-Impact</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Haeufig gestellte Fragen</h2>
				<div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Fuer wen ist das?</h3>
						<p class="text-[15px] text-muted">Die Conversion Audit Checkliste ist fuer Coaches, SaaS-Gruender und Berater, die Traffic haben, ihn aber nicht so gut in Umsatz umwandeln wie sie sollten. Wenn du vermutest, dass dein Funnel Leaks hat, aber nicht weisst, wo du anfangen sollst - das ist fuer dich.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">In welchem Format ist die Checkliste?</h3>
						<p class="text-[15px] text-muted">Du bekommst sowohl ein schoen gestaltetes PDF als auch ein Notion Template, sodass du digital oder ausgedruckt damit arbeiten kannst.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Brauche ich Vorkenntnisse?</h3>
						<p class="text-[15px] text-muted">Nein. Die Checkliste ist selbsterklaerend gestaltet. Jeder Punkt sagt dir genau, was du pruefen sollst und wie "bestanden" oder "durchgefallen" aussieht. Kein Marketing-Studium noetig.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Bottom -->
		<section class="border-t border-border px-6 py-24">
			<div class="content-width text-center">
				<div class="flex items-center justify-center gap-3 mb-6">
					<span class="font-display text-4xl font-bold text-text">&euro;47</span>
					<span class="text-xl text-muted-dark line-through">&euro;97</span>
					<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">50% RABATT</span>
				</div>
				<button disabled class="cta-primary opacity-50 cursor-not-allowed w-full" style="pointer-events:none;">Coming Soon</button>
				</div>
		</section>

		<Footer />
	</body>
</html>
