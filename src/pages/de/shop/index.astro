---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { brand } from '../../../config/brand';

const convAudit = brand.products.find(p => p.slug === "conversion-audit-checklist")!;
const revLeakMap = brand.products.find(p => p.slug === "revenue-leak-map-guide")!;
const auditTemplate = brand.products.find(p => p.slug === "revenue-leak-audit-template")!;
const playbook = brand.products.find(p => p.slug === "90-day-revenue-playbook")!;
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title="Shop - Digitale Produkte | UHL Systems" description="Revenue-Frameworks, Templates und Playbooks, die du sofort einsetzen kannst. Basierend auf der gleichen Methodik, die wir mit Kunden verwenden." />
		<style>
			.section-heading {
				font-size: clamp(32px, 5vw, 56px);
				line-height: 1.1;
				letter-spacing: -0.02em;
			}
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 14px 36px;
				font-weight: 600;
				transition: all 0.2s;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.cta-ghost {
				border: 1px solid var(--color-border);
				border-radius: 999px;
				padding: 14px 36px;
				color: var(--color-muted);
				transition: all 0.2s;
			}
			.cta-ghost:hover {
				border-color: var(--color-accent);
				color: var(--color-text);
			}
			.product-card {
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 40px 32px;
				transition: all 0.3s;
				display: flex;
				flex-direction: column;
			}
			.product-card:hover {
				border-color: rgba(0, 255, 136, 0.25);
				background: var(--color-bg3);
			}
			.content-width {
				max-width: 1100px;
				margin: 0 auto;
			}
			.prose-width {
				max-width: 720px;
				margin: 0 auto;
			}
		</style>
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="relative overflow-hidden px-6 py-24 md:py-36">
			<div class="content-width text-center">
				<p class="fade-in mb-6 font-mono text-sm tracking-widest text-accent uppercase">Digitale Produkte</p>
				<h1 class="hero-headline fade-in fade-in-delay-1 font-display font-bold text-text">
					Revenue-Tools zum Sofort-Einsatz
				</h1>
				<p class="fade-in fade-in-delay-2 mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-muted">
					Basierend auf den gleichen Frameworks, die wir mit Kunden verwenden. Templates, Guides und Playbooks, um deine Revenue Leaks selbst zu finden und zu beheben - in deinem eigenen Tempo.
				</p>
			</div>
			<div class="pointer-events-none absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0); background-size: 40px 40px;"></div>
			<div class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full" style="background: radial-gradient(circle, rgba(0,255,136,0.05) 0%, transparent 70%);"></div>
		</section>

		<!-- Products Grid -->
		<section class="border-t border-border px-6 py-28">
			<div class="content-width">
				<div class="grid gap-8 md:grid-cols-2">

					<!-- Product 1: Conversion Audit Checklist -->
					<div class="product-card">
						<div class="mb-4 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
							</div>
							<div>
								<h2 class="text-xl font-semibold text-text">Conversion Audit Checkliste</h2>
								<p class="font-mono text-xs tracking-wider text-muted-dark uppercase">50-Punkte-Checkliste</p>
							</div>
						</div>
						<p class="mb-6 text-[15px] leading-relaxed text-muted">
							50-Punkte-Checkliste, um jeden Schritt deines Funnels zu pruefen. Sofort umsetzbar.
						</p>
						<div class="mb-6 border-t border-border pt-6">
							<div class="flex items-center gap-3">
								<span class="font-display text-3xl font-bold text-text">&euro;47</span>
								<span class="text-lg text-muted-dark line-through">&euro;97</span>
								<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">50% RABATT</span>
							</div>
							<div class="mt-2 flex items-center gap-2">
								<span class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] tracking-wider text-accent uppercase">Digitaler Download - Sofort-Zugang</span>
							</div>
						</div>
						<div class="mt-auto space-y-3">
							<a href={convAudit.checkoutUrl} class="cta-primary block w-full text-center">
								Jetzt Zugang sichern &rarr;
							</a>
							<a href="/de/shop/conversion-audit-checklist" class="cta-ghost block w-full text-center">
								Mehr erfahren
							</a>
						</div>
					</div>

					<!-- Product 2: Revenue Leak Map PDF Guide -->
					<div class="product-card">
						<div class="mb-4 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="m9 15 3-3 3 3"/></svg>
							</div>
							<div>
								<h2 class="text-xl font-semibold text-text">Revenue Leak Map PDF Guide</h2>
								<p class="font-mono text-xs tracking-wider text-muted-dark uppercase">PDF Guide</p>
							</div>
						</div>
						<p class="mb-6 text-[15px] leading-relaxed text-muted">
							30-seitiger Guide zu allen 7 Revenue Leaks - Symptome, Diagnose und Loesung fuer jeden einzelnen.
						</p>
						<div class="mb-6 border-t border-border pt-6">
							<span class="font-display text-3xl font-bold text-text">&euro;97</span>
							<div class="mt-2 flex items-center gap-2">
								<span class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] tracking-wider text-accent uppercase">Digitaler Download - Sofort-Zugang</span>
							</div>
						</div>
						<div class="mt-auto space-y-3">
							<a href={revLeakMap.checkoutUrl} class="cta-primary block w-full text-center">
								Jetzt Zugang sichern &rarr;
							</a>
							<a href="/de/shop/revenue-leak-map-guide" class="cta-ghost block w-full text-center">
								Mehr erfahren
							</a>
						</div>
					</div>

					<!-- Product 3: Revenue Leak Audit Template (BESTSELLER) -->
					<div class="product-card" style="border-color: rgba(0, 255, 136, 0.3);">
						<div class="mb-4 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
							</div>
							<div>
								<h2 class="text-xl font-semibold text-text">Revenue Leak Audit Template</h2>
								<p class="font-mono text-xs tracking-wider text-muted-dark uppercase">DIY-Framework</p>
							</div>
						</div>
						<p class="mb-6 text-[15px] leading-relaxed text-muted">
							Komplettes DIY-Audit-Framework. Excel + Notion Template mit Formeln und Bewertungsleitfaden.
						</p>
						<div class="mb-6 border-t border-border pt-6">
							<div class="flex items-center gap-3">
								<span class="font-display text-3xl font-bold text-text">&euro;147</span>
								<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">Bestseller</span>
							</div>
							<div class="mt-2 flex items-center gap-2">
								<span class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] tracking-wider text-accent uppercase">Digitaler Download - Sofort-Zugang</span>
							</div>
						</div>
						<div class="mt-auto space-y-3">
							<a href={auditTemplate.checkoutUrl} class="cta-primary block w-full text-center">
								Jetzt Zugang sichern &rarr;
							</a>
							<a href="/de/shop/revenue-leak-audit-template" class="cta-ghost block w-full text-center">
								Mehr erfahren
							</a>
						</div>
					</div>

					<!-- Product 4: 90-Day Revenue System Playbook -->
					<div class="product-card">
						<div class="mb-4 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
							</div>
							<div>
								<h2 class="text-xl font-semibold text-text">90-Tage Revenue System Playbook</h2>
								<p class="font-mono text-xs tracking-wider text-muted-dark uppercase">Umsetzungsplan</p>
							</div>
						</div>
						<p class="mb-6 text-[15px] leading-relaxed text-muted">
							Woche-fuer-Woche Umsetzungsplan, um ein komplettes Revenue-System von Grund auf aufzubauen.
						</p>
						<div class="mb-6 border-t border-border pt-6">
							<span class="font-display text-3xl font-bold text-text">&euro;197</span>
							<div class="mt-2 flex items-center gap-2">
								<span class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] tracking-wider text-accent uppercase">Digitaler Download - Sofort-Zugang</span>
							</div>
						</div>
						<div class="mt-auto space-y-3">
							<span class="block w-full cursor-not-allowed rounded-full border border-border bg-transparent px-9 py-3.5 text-center font-semibold text-muted">
								Demnächst verfügbar
							</span>
							<a href="/de/shop/90-day-revenue-playbook" class="cta-ghost block w-full text-center">
								Mehr erfahren
							</a>
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- CTA to Services -->
		<section class="border-t border-border px-6 py-28">
			<div class="content-width text-center">
				<p class="mb-4 font-mono text-sm tracking-widest text-accent uppercase">Mehr gewuenscht?</p>
				<h2 class="section-heading mb-6 font-display font-bold text-text">
					Sollen wir es fuer dich machen?
				</h2>
				<p class="mx-auto mb-14 max-w-xl text-muted">
					Diese Tools sind bereits fuer sich genommen wirkungsvoll - aber wenn du praxisnahe Hilfe beim Finden und Beheben deiner Revenue Leaks willst, schau dir unsere Services an.
				</p>
				<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a href="/de/services/audit" class="cta-primary inline-flex items-center gap-2">
						Services entdecken
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
					<a href="/de/#contact" class="cta-ghost inline-flex items-center gap-2">
						Kontakt
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
