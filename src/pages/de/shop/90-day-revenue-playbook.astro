---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { brand } from '../../../config/brand';

const product = brand.products.find(p => p.slug === "90-day-revenue-playbook")!;
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title="90-Tage Revenue System Playbook | UHL Systems" description="Woche-fuer-Woche Umsetzungsplan, um ein komplettes Revenue-System von Grund auf aufzubauen. 13 Wochen mit taeglichen Aufgaben, KPI-Tracking und Meilenstein-Checklisten." />
		<style>
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(28px, 4vw, 44px);
				line-height: 1.15;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 16px 40px;
				font-weight: 600;
				font-size: 18px;
				transition: all 0.2s;
				display: inline-block;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.content-width {
				max-width: 820px;
				margin: 0 auto;
			}
			.feature-item {
				display: flex;
				align-items: flex-start;
				gap: 14px;
			}
			.feature-icon {
				flex-shrink: 0;
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				background: rgba(0, 255, 136, 0.1);
				color: var(--color-accent);
				margin-top: 2px;
			}
			.faq-item {
				border-bottom: 1px solid var(--color-border);
				padding: 24px 0;
			}
			.faq-item:last-child {
				border-bottom: none;
			}
		</style>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Fuer wen ist das?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Das 90-Tage Playbook ist fuer Business-Inhaber, die keine Lust mehr auf zufaellige Taktiken haben und ein strukturiertes System wollen. Ideal fuer Coaches, SaaS-Gruender und Berater, die in 13 Wochen ein Revenue-System von Traffic bis LTV aufbauen wollen."
					}
				},
				{
					"@type": "Question",
					"name": "In welchem Format ist das Playbook?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Du bekommst ein umfassendes PDF mit dem kompletten 13-Wochen-Plan plus Google Sheets Templates fuer KPI-Tracking, Meilenstein-Checklisten und Kundenkommunikation."
					}
				},
				{
					"@type": "Question",
					"name": "Brauche ich Vorkenntnisse?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Nein. Das Playbook startet bei Null und fuehrt dich durch jede Woche. Jede Aufgabe ist spezifisch und erklaert. Wenn du einem Rezept folgen kannst, kannst du diesem Playbook folgen."
					}
				}
			]
		}
		</script>
	</head>
	<body>
		<Header />

		<!-- Breadcrumb -->
		<div class="px-6 pt-28 pb-4">
			<div class="content-width">
				<nav class="flex items-center gap-2 font-mono text-sm text-muted-dark">
					<a href="/de/shop" class="transition-colors hover:text-accent">Shop</a>
					<span>&rarr;</span>
					<span class="text-muted">90-Tage Revenue System Playbook</span>
				</nav>
			</div>
		</div>

		<!-- Hero -->
		<section class="px-6 pb-20 pt-8">
			<div class="content-width">
				<span class="mb-6 inline-block rounded-full bg-accent/10 px-4 py-1.5 font-mono text-[11px] tracking-wider text-accent uppercase">Digitaler Download - Sofort-Zugang</span>
				<h1 class="hero-headline fade-in font-display font-bold text-text">
					90-Tage Revenue System Playbook
				</h1>
				<p class="fade-in fade-in-delay-1 mt-6 max-w-2xl text-lg leading-relaxed text-muted">
					Baue ein komplettes Revenue-System von Grund auf in 13 Wochen. Taegliche Aufgaben, woechentliche Meilensteine und KPI-Tracking - von Traffic bis Lifetime Value.
				</p>
				<div class="fade-in fade-in-delay-2 mt-10 flex flex-wrap items-center gap-5">
					<span class="font-display text-4xl font-bold text-text">&euro;197</span>
				</div>
				<div class="fade-in fade-in-delay-3 mt-8">
					<a href={product.checkoutUrl} class="cta-primary block w-full text-center">Jetzt kaufen - {product.price}</a>
				</div>
			</div>
		</section>

		<!-- What You Get -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Was du bekommst</h2>
				<div class="grid gap-6 sm:grid-cols-2">
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Woche-fuer-Woche Umsetzungsplan</p>
							<p class="mt-1 text-sm text-muted">13 Wochen geplant - jede Woche hat einen klaren Fokus</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Taegliche Aufgaben</p>
							<p class="mt-1 text-sm text-muted">Wisse genau, was du jeden einzelnen Tag tun musst</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">KPI-Tracking-Templates</p>
							<p class="mt-1 text-sm text-muted">Fortschritt messen mit vorgefertigten Tracking-Sheets</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Traffic &rarr; LTV Komplettsystem</p>
							<p class="mt-1 text-sm text-muted">End-to-End Revenue-System, nicht nur Taktiken</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Meilenstein-Checklisten</p>
							<p class="mt-1 text-sm text-muted">Klare Checkpoints, damit du weisst, dass du auf Kurs bist</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">E-Mail-Templates fuer Kundenkommunikation</p>
							<p class="mt-1 text-sm text-muted">Versandfertige Templates fuer jede Phase</p>
						</div>
					</div>
				</div>
				<p class="mt-8 font-mono text-sm text-muted-dark">Format: PDF + Google Sheets</p>
			</div>
		</section>

		<!-- Who This Is For -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Fuer wen ist das</h2>
				<div class="grid gap-8 sm:grid-cols-3">
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Coaches</p>
						<p class="text-[15px] text-muted">Du hast bisher alles Moegliche ausprobiert, aber nichts baut aufeinander auf. Du willst endlich ein System, das Schritt fuer Schritt waechst.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">SaaS-Gruender</p>
						<p class="text-[15px] text-muted">Du shippst Features, aber der Umsatz bleibt unberechenbar. Du brauchst einen Plan, der Revenue genauso systematisch aufbaut wie dein Produkt.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Berater</p>
						<p class="text-[15px] text-muted">Du willst ein fertiges System, das du selbst umsetzen oder fuer deine Kunden anpassen kannst. Plug and Play.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- What Problem It Solves -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Welches Problem es loest</h2>
				<div class="space-y-6 text-[16px] leading-relaxed text-muted">
					<p>
						Du weisst, dass du ein Revenue-System brauchst. Aber jedes Mal, wenn du dich hinsetzt, um eins aufzubauen, bleibst du stecken: Was kommt zuerst? Wie haengen die Teile zusammen? Arbeite ich diese Woche am Richtigen? Ohne einen Bauplan springst du zwischen Taktiken hin und her - diese Woche E-Mail-Sequenzen, naechste Woche Ads, dann eine neue Landing Page. Nichts baut aufeinander auf.
					</p>
					<p>
						Das 90-Tage Revenue System Playbook eliminiert dieses Chaos. Es gibt dir einen Woche-fuer-Woche-Umsetzungsplan, der dein gesamtes Revenue-System in der richtigen Reihenfolge aufbaut - von Traffic-Akquise ueber Conversion-Optimierung bis Lifetime-Value-Maximierung. Jede Woche baut auf der letzten auf, und jede taegliche Aufgabe hat einen klaren Zweck.
					</p>
					<p>
						Am Tag 90 hast du nicht einfach eine Sammlung von Taktiken. Du hast ein System: Traffic fliesst rein, Leads konvertieren, Kunden werden gehalten und Umsatz waechst vorhersehbar. Die KPI-Tracking-Templates zeigen dir bei jedem Meilenstein genau, wo du stehst, damit du nie den Ueberblick verlierst.
					</p>
				</div>
			</div>
		</section>

		<!-- Sample / Preview -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Das steckt drin</h2>
				<div class="rounded-xl border border-border bg-bg2 p-8">
					<ul class="space-y-4 text-[15px] text-muted">
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Woche 1-4: Fundament - Traffic-Audit, Funnel-Mapping, Conversion-Baseline und Quick Wins</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Woche 5-8: Aufbau - E-Mail-Sequenzen, Retargeting-Setup, Angebots-Optimierung und Upsell-System</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Woche 9-13: Skalierung - LTV-Maximierung, Empfehlungs-Engine, KPI-Dashboard und System-Automatisierung</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Bonus: 15+ E-Mail-Templates fuer Kundenkommunikation in jeder Phase des Revenue-Zyklus</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Haeufig gestellte Fragen</h2>
				<div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Fuer wen ist das?</h3>
						<p class="text-[15px] text-muted">Das 90-Tage Playbook ist fuer Business-Inhaber, die keine Lust mehr auf zufaellige Taktiken haben und ein strukturiertes System wollen. Ideal fuer Coaches, SaaS-Gruender und Berater, die in 13 Wochen ein Revenue-System von Traffic bis LTV aufbauen wollen.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">In welchem Format ist das Playbook?</h3>
						<p class="text-[15px] text-muted">Du bekommst ein umfassendes PDF mit dem kompletten 13-Wochen-Plan plus Google Sheets Templates fuer KPI-Tracking, Meilenstein-Checklisten und Kundenkommunikation.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Brauche ich Vorkenntnisse?</h3>
						<p class="text-[15px] text-muted">Nein. Das Playbook startet bei Null und fuehrt dich durch jede Woche. Jede Aufgabe ist spezifisch und erklaert. Wenn du einem Rezept folgen kannst, kannst du diesem Playbook folgen.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Bottom -->
		<section class="border-t border-border px-6 py-24">
			<div class="content-width text-center">
				<div class="mb-6">
					<span class="font-display text-4xl font-bold text-text">&euro;197</span>
				</div>
				<a href={product.checkoutUrl} class="cta-primary block w-full text-center">Jetzt kaufen - {product.price}</a>
				</div>
		</section>


	<!-- Upsell -->
	<section class="border-t border-border px-6 py-16 bg-bg2">
		<div class="mx-auto max-w-3xl text-center">
			<p class="font-mono text-xs tracking-widest text-accent uppercase mb-3">Naechster Schritt</p>
			<h3 class="font-display text-xl font-bold text-text mb-3">
				Willst du das volle Bild?
			</h3>
			<p class="text-muted text-sm mb-6 max-w-md mx-auto">
				Der Strategy Call nimmt deine Revenue Leak Map und macht daraus einen priorisierten Aktionsplan - spezifisch fuer dein Business.
			</p>
			<a href={brand.strategyCall.checkoutUrl} class="cta-primary inline-flex items-center gap-2">
				Strategy Call buchen - 97€
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
			<p class="mt-2 font-mono text-xs text-muted-dark">30 Min &nbsp;|&nbsp; 97€ &nbsp;|&nbsp; Zahlung bei Buchung</p>
		</div>
	</section>

		<Footer />
	</body>
</html>
