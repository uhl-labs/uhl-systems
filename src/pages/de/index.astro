		<script>
			// === UHL Method Cards: Scroll-in Animation ===
			(function() {
				var cards = document.querySelectorAll('[data-uhl-card]');
				if (!cards.length) return;
				var observer = new IntersectionObserver(function(entries) {
					entries.forEach(function(entry) {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
							observer.unobserve(entry.target);
						}
					});
				}, { threshold: 0.15 });
				cards.forEach(function(card) { observer.observe(card); });
			})();

			// === About Section: Scroll Reveal ===
			(function() {
				var aboutEls = document.querySelectorAll('.about-text-col, .about-photo-col');
				if (!aboutEls.length) return;
				var observer = new IntersectionObserver(function(entries) {
					entries.forEach(function(entry) {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
							observer.unobserve(entry.target);
						}
					});
				}, { threshold: 0.15 });
				aboutEls.forEach(function(el) { observer.observe(el); });
			})();

			// === Revenue Leak Calculator ===
			(function() {
				var traffic = document.getElementById('calc-traffic');
				var cr = document.getElementById('calc-cr');
				var aov = document.getElementById('calc-aov');
				var emailList = document.getElementById('calc-email');
				var actualInput = document.getElementById('calc-actual');
				var industrySelect = document.getElementById('calc-industry');
				if (!traffic || !cr || !aov || !emailList) return;

				var benchmarks = {
					saas: 0.03,
					ecom: 0.025,
					consulting: 0.08,
					agency: 0.10,
					coaching: 0.05,
					b2b: 0.12
				};
				var industryNames = {
					saas: 'SaaS / Software',
					ecom: 'E-Commerce',
					consulting: 'Consulting / Dienstleistung',
					agency: 'Agentur',
					coaching: 'Coaching / Kurse',
					b2b: 'B2B / Enterprise'
				};

				function fmt(n) {
					return '€' + Math.round(n).toLocaleString('de-DE');
				}

				function calc() {
					var t = parseInt(traffic.value) || 0;
					var c = (parseInt(cr.value) || 0) / 10000;
					var a = parseInt(aov.value) || 0;
					var el = parseInt(emailList.value) || 0;
					var actual = parseInt(actualInput.value) || 0;
					var selectedIndustry = industrySelect.value;
					var industryBenchmark = benchmarks[selectedIndustry] || 0.02;
					var industryName = industryNames[selectedIndustry] || selectedIndustry;

					document.getElementById('calc-traffic-val').textContent = t.toLocaleString('de-DE');
					document.getElementById('calc-cr-val').textContent = (c * 100).toFixed(1).replace('.', ',') + '%';
					document.getElementById('calc-aov-val').textContent = '€' + a.toLocaleString('de-DE');
					document.getElementById('calc-email-val').textContent = el.toLocaleString('de-DE');
					document.getElementById('calc-actual-val').textContent = actual > 0 ? fmt(actual) : '€ eingeben';

					var theoretical = t * c * a;
					var benchmarkRev = t * industryBenchmark * a;

					document.getElementById('calc-benchmark-sub').textContent = (industryBenchmark * 100) + '% CR Benchmark für ' + industryName;

					// Block 1: Aktueller Stand
					var currentEl = document.getElementById('calc-current');
					var currentSub = document.getElementById('calc-current-sub');
					if (actual > 0) {
						currentEl.textContent = fmt(actual);
						currentSub.textContent = 'Dein echter Umsatz';
					} else {
						currentEl.textContent = fmt(theoretical) + ' (gesch\u00e4tzt)';
						currentSub.textContent = 'Basierend auf deinen Eingaben';
					}
					document.getElementById('calc-benchmark').textContent = fmt(benchmarkRev) + '/Mo';

					var compareEl = document.getElementById('calc-benchmark-compare');
					if (actual > 0) {
						compareEl.style.display = 'block';
						if (actual < benchmarkRev) {
							var gap = benchmarkRev - actual;
							compareEl.innerHTML = '<span style="color: #ef4444;">Du liegst ' + fmt(gap) + ' unter dem Benchmark</span>';
						} else {
							compareEl.innerHTML = '<span style="color: #22c55e;">\u2713 \u00dcber Benchmark</span>';
						}
					} else {
						compareEl.style.display = 'none';
					}

					// Block 2: Wo du Umsatz verlierst
					var convGap = 0;
					var convLabel = document.getElementById('calc-conv-label');
					var convGapEl = document.getElementById('calc-conv-gap');
					var convSub = document.getElementById('calc-conv-sub');

					var benchmarkPct = (industryBenchmark * 100) + '%';
					if (actual > 0) {
						convGap = Math.max(0, benchmarkRev - actual);
						if (convGap > 0) {
							convLabel.textContent = 'Conversion-L\u00fccke';
							convGapEl.textContent = '+' + fmt(convGap) + '/Mo';
							convGapEl.className = 'calc-item-value calc-value-red';
							convSub.textContent = 'Differenz zwischen deinem Umsatz und ' + benchmarkPct + ' ' + industryName + ' Benchmark';
						} else {
							convLabel.textContent = 'Conversion-L\u00fccke';
							convGapEl.textContent = '\u2713 \u00dcber Benchmark';
							convGapEl.className = 'calc-item-value calc-value-green';
							convSub.textContent = 'Du liegst bereits \u00fcber dem ' + benchmarkPct + ' ' + industryName + ' Benchmark';
						}
					} else {
						if (c >= industryBenchmark) {
							convLabel.textContent = 'Conversion-L\u00fccke';
							convGapEl.textContent = '\u2713 \u00dcber Benchmark';
							convGapEl.className = 'calc-item-value calc-value-green';
							convSub.textContent = 'Branchen-Benchmark f\u00fcr ' + industryName;
						} else {
							convGap = Math.max(0, benchmarkRev - theoretical);
							convLabel.textContent = 'Branchen-Benchmark f\u00fcr ' + industryName;
							convGapEl.textContent = '+' + fmt(convGap) + '/Mo';
							convGapEl.className = 'calc-item-value calc-value-red';
							convSub.textContent = 'Bei ' + benchmarkPct + ' Conversion Rate';
						}
					}

					var emailRow = document.getElementById('calc-email-row');
					var emailGap = 0;
					if (el > 0) {
						emailRow.style.display = 'flex';
						emailGap = el * 0.01 * a;
						document.getElementById('calc-email-gap').textContent = '+' + fmt(emailGap) + '/Mo';
					} else {
						emailRow.style.display = 'none';
					}

					var annualStake = convGap * 12;
					document.getElementById('calc-annual-stake').textContent = fmt(annualStake) + '/Jahr';

					// Block 3: Gesamtpotenzial
					var totalOpp = convGap + emailGap;
					document.getElementById('calc-total-opp').textContent = '+' + fmt(totalOpp) + '/Mo';
					var totalSub = document.getElementById('calc-total-sub');
					if (actual > 0) {
						totalSub.textContent = 'Das l\u00e4sst du jeden Monat auf dem Tisch liegen.';
					} else {
						totalSub.textContent = 'Dein gesch\u00e4tztes monatliches Potenzial.';
					}
				}

				traffic.addEventListener('input', calc);
				cr.addEventListener('input', calc);
				aov.addEventListener('input', calc);
				emailList.addEventListener('input', calc);
				actualInput.addEventListener('input', calc);
				industrySelect.addEventListener('change', calc);
				calc();
			})();

			// === Newsletter Form ===
			(function() {
				var form = document.getElementById('newsletter-form');
				if (!form) return;
				form.addEventListener('submit', function(e) {
					e.preventDefault();
					var emailInput = form.querySelector('input[type="email"]');
					var btn = form.querySelector('button[type="submit"]');
					if (!emailInput || !btn) return;
					var email = emailInput.value;
					if (!email) return;
					btn.disabled = true;
					btn.textContent = '...';

					fetch('/api/subscribe', {
						method: 'POST',
						headers: {
							'Authorization': 'Bearer re_QNyWMxZH_9XJAKj52q5KZKSfnsvgpfdQU',
							'Content-Type': 'application/json'
						},
						body: JSON.stringify({ email: email, lang: 'de' })
					})
					.then(function() {
						form.style.display = 'none';
						document.getElementById('newsletter-thanks').classList.remove('hidden');
					})
					.catch(function() {
						localStorage.setItem('uhl_sub_email', email);
						localStorage.setItem('uhl_sub_date', new Date().toISOString());
						form.style.display = 'none';
						document.getElementById('newsletter-thanks').classList.remove('hidden');
					});
				});
			})();
		</script>
	</body>
</html>
