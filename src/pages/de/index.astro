---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import RevenueMuncher from '../../components/RevenueMuncher.astro';
import { brand } from '../../config/brand';
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title="UHL Systems - Unlock Hidden Leverage | Revenue Systeme" description="Wir finden die Revenue Leaks in deinem Business und beheben sie. Revenue Leak Audit ab 1k - 2k." isHomepage={false} />
		<link rel="canonical" href="https://www.uhl-systems.com/de/" />
		<style>
			.hero-headline {
				font-size: clamp(2rem, 9vw, 7rem);
				font-weight: 800;
				line-height: 1.05;
				letter-spacing: -0.03em;
				text-align: center;
				overflow: hidden;
				max-width: 100%;
			}
			@media (max-width: 480px) {
				.hero-headline {
					font-size: clamp(1.8rem, 11vw, 3rem);
				}
			}
			.section-heading {
				font-size: clamp(32px, 5vw, 56px);
				line-height: 1.1;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 14px 36px;
				font-weight: 600;
				transition: all 0.2s;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.cta-ghost {
				border: 1px solid var(--color-border);
				border-radius: 999px;
				padding: 14px 36px;
				color: var(--color-muted);
				transition: all 0.2s;
			}
			.cta-ghost:hover {
				border-color: var(--color-accent);
				color: var(--color-text);
			}
			.uhl-card {
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 40px 32px;
				transition: all 0.3s;
			}
			.uhl-card:hover {
				border-color: rgba(0, 255, 136, 0.25);
				background: var(--color-bg3);
			}
			.content-width {
				max-width: 1100px;
				margin: 0 auto;
			}

			/* === Credibility Bar === */
			.credibility-bar {
				border-top: 1px solid var(--color-border);
				border-bottom: 1px solid var(--color-border);
				background: #111;
			}
			.credibility-grid {
				display: flex;
				justify-content: center;
				align-items: baseline;
				gap: 3rem;
				text-align: center;
				padding: 2.5rem 1.5rem;
				max-width: 1000px;
				margin: 0 auto;
			}
			.credibility-item {
				display: flex;
				align-items: baseline;
				gap: 0.5rem;
				white-space: nowrap;
			}
			.credibility-number {
				font-size: clamp(28px, 4vw, 40px);
				font-weight: 800;
				color: var(--color-accent);
				line-height: 1;
				font-family: var(--font-display);
			}
			.credibility-label {
				font-size: 14px;
				color: var(--color-muted);
				line-height: 1.3;
			}
			.credibility-divider {
				width: 1px;
				height: 32px;
				background: var(--color-border);
				flex-shrink: 0;
			}
			@media (max-width: 768px) {
				.credibility-grid {
					display: flex;
					flex-direction: row;
					flex-wrap: nowrap;
					justify-content: space-around;
					gap: 0.5rem;
					padding: 1.75rem 1rem;
				}
				.credibility-item {
					flex-direction: column;
					align-items: center;
					gap: 0.25rem;
					flex: 1;
					min-width: 0;
					white-space: normal;
					text-align: center;
				}
				.credibility-number {
					font-size: clamp(22px, 6vw, 32px);
				}
				.credibility-label {
					font-size: 11px;
					line-height: 1.3;
				}
				.credibility-divider { display: none; }
			}

			/* === Case Studies === */
			.case-card {
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 32px 28px;
				transition: all 0.3s;
			}
			.case-card:hover {
				border-color: rgba(0, 255, 136, 0.25);
				background: var(--color-bg3);
			}
			.case-before { color: #ff4444; font-weight: 700; }
			.case-after { color: #00ff88; font-weight: 700; }
			.case-arrow { color: var(--color-muted-dark); margin: 0 0.35rem; }

			/* === Ways to Work Together === */
			.ways-card {
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 32px 28px;
				transition: all 0.3s;
				display: flex;
				flex-direction: column;
			}
			.ways-card:hover {
				border-color: rgba(0, 255, 136, 0.25);
				background: var(--color-bg3);
			}
			.ways-price {
				font-family: var(--font-display);
				font-size: 24px;
				font-weight: 700;
				color: var(--color-accent);
			}

			/* === FAQ Section === */
			.faq-item {
				border-bottom: 1px solid var(--color-border);
			}
			.faq-item summary {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 1.25rem 0;
				cursor: pointer;
				font-size: 17px;
				font-weight: 600;
				color: var(--color-text);
				list-style: none;
				transition: color 0.2s;
			}
			.faq-item summary::-webkit-details-marker { display: none; }
			.faq-item summary::after {
				content: '+';
				font-size: 24px;
				font-weight: 300;
				color: var(--color-accent);
				transition: transform 0.2s;
				flex-shrink: 0;
				margin-left: 1rem;
			}
			.faq-item[open] summary::after {
				transform: rotate(45deg);
			}
			.faq-item summary:hover { color: var(--color-accent); }
			.faq-answer {
				padding: 0 0 1.25rem;
				font-size: 15px;
				line-height: 1.7;
				color: var(--color-muted);
				max-width: 640px;
			}

			/* === Revenue Leak Map === */
			.leak-flow {
				display: flex;
				align-items: flex-start;
				gap: 0;
				padding-bottom: 1rem;
			}
			.leak-station {
				flex: 1;
				min-width: 120px;
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				position: relative;
				transition: transform 0.3s ease;
			}
			.leak-flow > :nth-child(4n+3) {
				transform: translateY(28px);
			}
			.leak-card {
				border: 1px solid #1a1a1a;
				background: var(--color-bg2);
				border-radius: 14px;
				padding: 20px 12px 16px;
				transition: all 0.35s ease;
				width: 100%;
				cursor: default;
			}
			.leak-card:hover {
				border-color: #00ff88;
				box-shadow: 0 0 24px rgba(0, 255, 136, 0.15), 0 0 48px rgba(0, 255, 136, 0.05);
				background: var(--color-bg3);
			}
			.leak-card:hover .leak-icon-wrap {
				background: rgba(0, 255, 136, 0.12);
			}
			.leak-card:hover .leak-hover-desc {
				opacity: 1;
			}
			.leak-icon-wrap {
				width: 44px;
				height: 44px;
				border-radius: 10px;
				background: var(--color-bg3);
				display: flex;
				align-items: center;
				justify-content: center;
				margin: 0 auto 10px;
				transition: background 0.3s;
			}
			.leak-number {
				font-family: var(--font-mono);
				font-size: 10px;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--color-muted-dark);
			}
			.leak-title {
				font-size: 13px;
				font-weight: 600;
				color: var(--color-text);
				margin-top: 4px;
				line-height: 1.3;
			}
			.leak-hover-desc {
				font-size: 11px;
				color: var(--color-muted);
				margin-top: 4px;
				line-height: 1.4;
				opacity: 0.7;
			}
			.leak-badge {
				position: absolute;
				top: 8px;
				right: 8px;
				font-size: 9px;
				font-family: monospace;
				color: #ff4444;
				opacity: 0.6;
				letter-spacing: 1px;
			}
			.leak-lightning {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				position: relative;
				padding: 0 8px;
				flex-shrink: 0;
			}
			.leak-lightning svg { display: none; }
			.leak-lightning::before {
				content: "";
				display: block;
				width: 48px;
				height: 2px;
				background: #e8ff00;
				border-radius: 2px;
				box-shadow: 0 0 8px rgba(232, 255, 0, 0.6), 0 0 20px rgba(232, 255, 0, 0.3);
				animation: flow-pulse 2s ease-in-out infinite;
				margin-bottom: 4px;
			}
			@keyframes flow-pulse {
				0%, 100% { opacity: 0.6; box-shadow: 0 0 6px rgba(232, 255, 0, 0.4), 0 0 14px rgba(232, 255, 0, 0.2); }
				50% { opacity: 1; box-shadow: 0 0 12px rgba(232, 255, 0, 0.9), 0 0 28px rgba(232, 255, 0, 0.5); }
			}
			.leak-warning {
				display: flex;
				align-items: center;
				justify-content: center;
				margin-top: 4px;
				position: relative;
			}
			.leak-stage-icon {
				width: 22px;
				height: 22px;
				color: #00ff88;
				opacity: 0.5;
				transition: all 0.3s ease;
				cursor: pointer;
				filter: drop-shadow(0 0 0px transparent);
			}
			.leak-warning:hover .leak-stage-icon {
				opacity: 1;
				transform: scale(1.2);
				filter: drop-shadow(0 0 8px rgba(0, 255, 136, 0.5));
			}
			.leak-tooltip {
				position: absolute;
				bottom: calc(100% + 10px);
				left: 50%;
				transform: translateX(-50%);
				background: #111;
				border: 1px solid rgba(232, 255, 0, 0.3);
				border-radius: 8px;
				padding: 10px 14px;
				font-size: 11px;
				font-family: var(--font-mono);
				color: var(--color-text);
				line-height: 1.5;
				white-space: normal;
				width: 200px;
				text-align: center;
				opacity: 0;
				visibility: hidden;
				transition: all 0.25s ease;
				pointer-events: none;
				z-index: 10;
				box-shadow: 0 0 20px rgba(232, 255, 0, 0.08);
			}
			.leak-tooltip::after {
				content: '';
				position: absolute;
				top: 100%;
				left: 50%;
				transform: translateX(-50%);
				border: 5px solid transparent;
				border-top-color: rgba(232, 255, 0, 0.3);
			}
			.leak-warning:hover .leak-tooltip {
				opacity: 1;
				visibility: visible;
			}
			@media (max-width: 767px) {
				.leak-flow {
					overflow-x: auto;
					flex-wrap: nowrap;
					-webkit-overflow-scrolling: touch;
					padding-bottom: 1rem;
					gap: 0;
				}
				.leak-station {
					min-width: 130px;
					flex-shrink: 0;
				}
				.leak-flow > :nth-child(4n+3) {
					transform: none;
				}
				.leak-lightning {
					flex-shrink: 0;
				}
			}

			/* === Revenue Calculator === */
			.calc-wrapper {
				max-width: 640px;
				margin: 0 auto;
			}
			.calc-field {
				margin-bottom: 1.5rem;
			}
			.calc-field label {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				font-size: 14px;
				font-weight: 600;
				color: var(--color-text);
				margin-bottom: 0.5rem;
			}
			.calc-field label span {
				font-family: var(--font-mono);
				font-size: 13px;
				color: var(--color-accent);
			}
			.calc-slider {
				-webkit-appearance: none;
				appearance: none;
				width: 100%;
				height: 6px;
				border-radius: 3px;
				background: var(--color-bg3);
				outline: none;
			}
			.calc-slider::-webkit-slider-thumb {
				-webkit-appearance: none;
				appearance: none;
				width: 20px;
				height: 20px;
				border-radius: 50%;
				background: var(--color-accent);
				cursor: pointer;
				box-shadow: 0 0 8px rgba(0, 255, 136, 0.4);
			}
			.calc-slider::-moz-range-thumb {
				width: 20px;
				height: 20px;
				border-radius: 50%;
				background: var(--color-accent);
				cursor: pointer;
				border: none;
				box-shadow: 0 0 8px rgba(0, 255, 136, 0.4);
			}
			.calc-block {
				border-radius: 12px;
				padding: 20px;
				margin-bottom: 12px;
			}
			.calc-block-neutral { background: var(--color-bg2); border: 1px solid var(--color-border); }
			.calc-block-danger { background: rgba(255,68,68,0.05); border: 1px solid rgba(255,68,68,0.2); }
			.calc-block-opportunity { background: rgba(232,255,0,0.05); border: 1px solid rgba(232,255,0,0.3); }
			.calc-block-title { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--color-muted); margin-bottom: 12px; font-family: monospace; }
			.calc-big-number { font-size: 28px; font-weight: 800; font-family: var(--font-display); }
			.calc-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
			.calc-item:last-child { border-bottom: none; }
			.calc-item-label { font-size: 13px; color: var(--color-muted); }
			.calc-item-sublabel { font-size: 10px; color: var(--color-muted-dark, rgba(255,255,255,0.3)); margin-top: 2px; }
			.calc-item-value { font-size: 15px; font-weight: 600; text-align: right; }
			.calc-value-red { color: #ff4444; }
			.calc-value-green { color: #00ff88; }
			.calc-value-yellow { color: #e8ff00; }

			/* === UHL Method Cards === */
			.uhl-method-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
			}
			@media (max-width: 768px) {
				.uhl-method-grid { grid-template-columns: 1fr; }
			}
			.uhl-method-card {
				position: relative;
				overflow: hidden;
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 48px 32px 40px;
				transition: all 0.4s ease;
				opacity: 0;
				transform: translateY(40px);
			}
			.uhl-method-card.visible {
				opacity: 1;
				transform: translateY(0);
			}
			.uhl-method-card:hover {
				border-color: rgba(0, 255, 136, 0.35);
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.08);
				background: var(--color-bg3);
			}
			.uhl-watermark {
				position: absolute;
				top: -20px;
				right: -10px;
				font-size: 180px;
				font-weight: 900;
				font-family: var(--font-display);
				color: rgba(0, 255, 136, 0.04);
				line-height: 1;
				pointer-events: none;
				user-select: none;
			}
			.uhl-method-letter {
				font-size: 28px;
				font-weight: 700;
				color: var(--color-accent);
				font-family: var(--font-display);
				position: relative;
			}
			.uhl-method-title {
				font-size: 20px;
				font-weight: 600;
				color: var(--color-text);
				margin-top: 12px;
				position: relative;
			}
			/* === About Section === */
			@media (max-width: 767px) {
				.about-photo { max-height: 400px !important; }
				.about-photo-wrapper { transform: rotate(0deg) !important; }
			}
			.about-text-col {
				opacity: 0;
				transform: translateX(40px);
				transition: opacity 0.8s ease, transform 0.8s ease;
			}
			.about-text-col.visible {
				opacity: 1;
				transform: translateX(0);
			}
			.about-photo-col {
				opacity: 0;
				transform: translateY(30px);
				transition: opacity 0.7s ease, transform 0.7s ease;
			}
			.about-photo-col.visible {
				opacity: 1;
				transform: translateY(0);
			}

			.uhl-method-desc {
				font-size: 15px;
				color: var(--color-muted);
				line-height: 1.7;
				margin-top: 12px;
				position: relative;
			}
		</style>
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="relative overflow-hidden px-6 py-28 md:py-40">
			<div class="content-width text-center">
				<p class="fade-in mb-8 font-mono text-sm tracking-widest text-accent uppercase">Revenue Systems Architecture</p>
				<h1 class="hero-headline fade-in fade-in-delay-1 font-display text-text">
					Unlock <span class="text-accent hero-hidden-word">Hidden</span> Leverage.
				</h1>
				<p class="fade-in fade-in-delay-2 mx-auto mt-8 text-muted" style="max-width: 560px; line-height: 1.65; font-size: clamp(1rem, 2vw, 1.2rem)">
					Die meisten Unternehmen optimieren Fragmente. Wir bauen das vollst&auml;ndige Revenue-System - vom ersten Klick bis zum Lifetime Value.
				</p>
				<div class="fade-in fade-in-delay-3 mt-14 flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a href="#contact" class="cta-primary inline-flex items-center gap-2">
						Revenue Leaks finden
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
					<a href="#method" class="cta-ghost inline-flex items-center gap-2">
						Methode entdecken
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</div>
			<!-- Background grid effect -->
			<div class="pointer-events-none absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0); background-size: 40px 40px;"></div>
			<div class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full" style="background: radial-gradient(circle, rgba(0,255,136,0.05) 0%, transparent 70%);"></div>
		</section>

		<RevenueMuncher tagline="wir fressen deine Revenue Leaks" />

		<!-- Credibility Bar -->
		<section class="credibility-bar">
			<div class="credibility-grid">
				<div class="credibility-item">
					<span class="credibility-number">50%</span>
					<span class="credibility-label">Durchschnittliche Kostensenkung</span>
				</div>
				<div class="credibility-divider"></div>
				<div class="credibility-item">
					<span class="credibility-number">2x</span>
					<span class="credibility-label">Umsatzwachstum erzielt</span>
				</div>
				<div class="credibility-divider"></div>
				<div class="credibility-item">
					<span class="credibility-number">90min</span>
					<span class="credibility-label">Bis zu ersten Insights</span>
				</div>
			</div>
			<p class="text-center text-xs tracking-wide text-muted-dark pb-4" style="margin-top: -0.5rem;">Das sind unsere Standards.</p>
		</section>

		<!-- Case Studies -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<p class="mb-4 text-center font-mono text-sm tracking-widest text-accent uppercase">Echte Ergebnisse</p>
				<h2 class="section-heading mb-16 text-center font-display font-bold text-text">
					Vorher &amp; Nachher.
				</h2>

				<div class="grid gap-6 md:grid-cols-3">
					<div class="case-card">
						<p class="mb-1 font-mono text-xs tracking-wider text-muted-dark uppercase">Online Business</p>
						<p class="mb-4 text-lg font-semibold text-text">
							<span class="case-before">Kosten &minus;50%</span><span class="case-arrow">&rarr;</span><span class="case-after">Umsatz stabil</span>
						</p>
						<p class="text-[15px] leading-relaxed text-muted">Betriebskosten halbiert, Umsatz unveraendert. Gleicher Output, halbe Kosten. Aber der eigentliche Gewinn: Umsatz der jetzt planbar reinkommt, nicht mehr in zufalligen Spitzen.</p>
					</div>

					<div class="case-card">
						<p class="mb-1 font-mono text-xs tracking-wider text-muted-dark uppercase">Coaching Business</p>
						<p class="mb-4 text-lg font-semibold text-text">
							<span class="case-before">Gleiche Kosten</span><span class="case-arrow">&rarr;</span><span class="case-after">Umsatz +40%</span>
						</p>
						<p class="text-[15px] leading-relaxed text-muted">Kein neues Budget. Keine neuen Kanaele. Wir haben die Conversion-Logik repariert und den Leak in der Angebotsstruktur gestopft. 40% mehr Umsatz aus exakt demselben Traffic.</p>
					</div>

					<div class="case-card">
