---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts
		.filter((post) => post.data.lang === 'de')
		.map((post) => ({
			params: { slug: post.id },
			props: post,
		}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog'))
	.filter((p) => p.data.lang === 'de' && p.id !== post.id)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentTags = post.data.tags || [];

const scored = allPosts.map((p) => {
	const shared = (p.data.tags || []).filter((t: string) => currentTags.includes(t)).length;
	return { post: p, shared };
});
scored.sort((a, b) => b.shared - a.shared || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf());

const relatedPosts = scored.slice(0, 3).map((s) => ({
	id: s.post.id,
	title: s.post.data.title,
	description: s.post.data.description,
	pubDate: s.post.data.pubDate,
	heroImage: s.post.data.heroImage,
	href: `/de/blog/${s.post.id}/`,
}));
---

<BlogPost {...post.data} relatedPosts={relatedPosts} lang="de">
	<Content />
</BlogPost>
