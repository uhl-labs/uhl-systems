				<h2 class="mb-3 font-display text-2xl font-bold text-text md:text-3xl">
					Get the Revenue Leak Map - Free
				</h2>
				<p class="mb-8 text-muted">
					Weekly insights on fixing revenue leaks. No fluff. Unsubscribe anytime.
				</p>
				<form id="newsletter-form" class="flex flex-col gap-3 sm:flex-row">
					<input
						type="email"
						required
						placeholder="email@example.com"
						class="flex-1 rounded-full border border-border bg-bg2 px-5 py-3 text-text placeholder-muted-dark outline-none transition-colors focus:border-accent"
					/>
					<button type="submit" class="cta-primary whitespace-nowrap">
						Subscribe →
					</button>
				</form>
				<p id="newsletter-thanks" class="mt-4 hidden text-sm font-medium text-accent">
					Thanks! Check your inbox.
				</p>
				<p class="mt-4 text-xs text-muted-dark">
					Join 0+ operators building better systems. Free guide included with every signup.
				</p>
			</div>
		</section>

		<Footer />

		<script>
			// === UHL Method Cards: Scroll-in Animation ===
			(function() {
				var cards = document.querySelectorAll('[data-uhl-card]');
				if (!cards.length) return;
				var observer = new IntersectionObserver(function(entries) {
					entries.forEach(function(entry) {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
							observer.unobserve(entry.target);
						}
					});
				}, { threshold: 0.15 });
				cards.forEach(function(card) { observer.observe(card); });
			})();

			// === About Section: Scroll Reveal ===
		(function() {
			var aboutEls = document.querySelectorAll('.about-text-col, .about-photo-col');
			if (!aboutEls.length) return;
			var observer = new IntersectionObserver(function(entries) {
				entries.forEach(function(entry) {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.15 });
			aboutEls.forEach(function(el) { observer.observe(el); });
		})();

		// === Newsletter Form ===
			(function() {
				var form = document.getElementById('newsletter-form');
				if (!form) return;
				form.addEventListener('submit', function(e) {
					e.preventDefault();
					form.style.display = 'none';
					document.getElementById('newsletter-thanks').classList.remove('hidden');
				});
			})();
		</script>
	</body>
</html>
