---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import RevenueMuncher from '../components/RevenueMuncher.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { brand } from '../config/brand';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} - Unlock Hidden Leverage`} description={SITE_DESCRIPTION} isHomepage={true} />
		<style>
			.hero-headline {
				font-size: clamp(48px, 8vw, 96px);
				line-height: 1.05;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(32px, 5vw, 56px);
				line-height: 1.1;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 14px 36px;
				font-weight: 600;
				transition: all 0.2s;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.cta-ghost {
				border: 1px solid var(--color-border);
				border-radius: 999px;
				padding: 14px 36px;
				color: var(--color-muted);
				transition: all 0.2s;
			}
			.cta-ghost:hover {
				border-color: var(--color-accent);
				color: var(--color-text);
			}
			.uhl-card {
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 40px 32px;
				transition: all 0.3s;
			}
			.uhl-card:hover {
				border-color: rgba(0, 255, 136, 0.25);
				background: var(--color-bg3);
			}
			.content-width {
				max-width: 1100px;
				margin: 0 auto;
			}

			/* === Credibility Bar === */
			.credibility-bar {
				border-top: 1px solid var(--color-border);
				border-bottom: 1px solid var(--color-border);
				background: #111;
			}
			.credibility-grid {
				display: flex;
				justify-content: center;
				align-items: baseline;
				gap: 3rem;
				text-align: center;
				padding: 2.5rem 1.5rem;
				max-width: 1000px;
				margin: 0 auto;
			}
			.credibility-item {
				display: flex;
				align-items: baseline;
				gap: 0.5rem;
				white-space: nowrap;
			}
			.credibility-number {
				font-size: clamp(28px, 4vw, 40px);
				font-weight: 800;
				color: var(--color-accent);
				line-height: 1;
				font-family: var(--font-display);
			}
			.credibility-label {
				font-size: 14px;
				color: var(--color-muted);
				line-height: 1.3;
			}
			.credibility-divider {
				width: 1px;
				height: 32px;
				background: var(--color-border);
				flex-shrink: 0;
			}
			@media (max-width: 768px) {
				.credibility-grid {
					display: grid;
					grid-template-columns: 1fr 1fr;
					gap: 1.5rem;
				}
				.credibility-divider { display: none; }
				.credibility-item { justify-content: center; }
			}

			/* === Ways to Work Together === */
			.ways-card {
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 32px 28px;
				transition: all 0.3s;
				display: flex;
				flex-direction: column;
			}
			.ways-card:hover {
				border-color: rgba(0, 255, 136, 0.25);
				background: var(--color-bg3);
			}
			.ways-price {
				font-family: var(--font-display);
				font-size: 24px;
				font-weight: 700;
				color: var(--color-accent);
			}

			/* === FAQ Section === */
			.faq-item {
				border-bottom: 1px solid var(--color-border);
			}
			.faq-item summary {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 1.25rem 0;
				cursor: pointer;
				font-size: 17px;
				font-weight: 600;
				color: var(--color-text);
				list-style: none;
				transition: color 0.2s;
			}
			.faq-item summary::-webkit-details-marker { display: none; }
			.faq-item summary::after {
				content: '+';
				font-size: 24px;
				font-weight: 300;
				color: var(--color-accent);
				transition: transform 0.2s;
				flex-shrink: 0;
				margin-left: 1rem;
			}
			.faq-item[open] summary::after {
				transform: rotate(45deg);
			}
			.faq-item summary:hover { color: var(--color-accent); }
			.faq-answer {
				padding: 0 0 1.25rem;
				font-size: 15px;
				line-height: 1.7;
				color: var(--color-muted);
				max-width: 640px;
			}

			/* === Revenue Leak Map === */
			.leak-flow {
				display: flex;
				align-items: flex-start;
				gap: 0;
				padding-bottom: 1rem;
			}
			.leak-station {
				flex: 1;
				min-width: 120px;
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				position: relative;
			}
			.leak-card {
				border: 1px solid #1a1a1a;
				background: var(--color-bg2);
				border-radius: 14px;
				padding: 20px 12px 16px;
				transition: all 0.35s ease;
				width: 100%;
				cursor: default;
			}
			.leak-card:hover {
				border-color: #00ff88;
				box-shadow: 0 0 24px rgba(0, 255, 136, 0.15), 0 0 48px rgba(0, 255, 136, 0.05);
				background: var(--color-bg3);
			}
			.leak-card:hover .leak-icon-wrap {
				background: rgba(0, 255, 136, 0.12);
			}
			.leak-card:hover .leak-hover-desc {
				opacity: 1;
				transform: translateY(0);
			}
			.leak-icon-wrap {
				width: 44px;
				height: 44px;
				border-radius: 10px;
				background: var(--color-bg3);
				display: flex;
				align-items: center;
				justify-content: center;
				margin: 0 auto 10px;
				transition: background 0.3s;
			}
			.leak-number {
				font-family: var(--font-mono);
				font-size: 10px;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--color-muted-dark);
			}
			.leak-title {
				font-size: 13px;
				font-weight: 600;
				color: var(--color-text);
				margin-top: 4px;
				line-height: 1.3;
			}
			.leak-hover-desc {
				font-size: 11px;
				color: var(--color-muted-dark);
				margin-top: 8px;
				line-height: 1.4;
				opacity: 0;
				transform: translateY(4px);
				transition: all 0.3s;
			}
			.leak-arrow {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				padding: 0 2px;
				flex-shrink: 0;
				margin-top: 30px;
			}
			.leak-arrow-line {
				width: 24px;
				height: 1px;
				background: linear-gradient(90deg, rgba(0, 255, 136, 0.3), rgba(0, 255, 136, 0.1));
			}
			.leak-warning {
				display: flex;
				align-items: center;
				justify-content: center;
				margin-top: 4px;
				position: relative;
			}
			.leak-stage-icon {
				width: 22px;
				height: 22px;
				color: #00ff88;
				opacity: 0.5;
				transition: all 0.3s ease;
				cursor: pointer;
				filter: drop-shadow(0 0 0px transparent);
			}
			.leak-warning:hover .leak-stage-icon {
				opacity: 1;
				transform: scale(1.2);
				filter: drop-shadow(0 0 8px rgba(0, 255, 136, 0.5));
			}
			.leak-tooltip {
				position: absolute;
				bottom: calc(100% + 10px);
				left: 50%;
				transform: translateX(-50%);
				background: #111;
				border: 1px solid rgba(232, 255, 0, 0.3);
				border-radius: 8px;
				padding: 10px 14px;
				font-size: 11px;
				font-family: var(--font-mono);
				color: var(--color-text);
				line-height: 1.5;
				white-space: normal;
				width: 200px;
				text-align: center;
				opacity: 0;
				visibility: hidden;
				transition: all 0.25s ease;
				pointer-events: none;
				z-index: 10;
				box-shadow: 0 0 20px rgba(232, 255, 0, 0.08);
			}
			.leak-tooltip::after {
				content: '';
				position: absolute;
				top: 100%;
				left: 50%;
				transform: translateX(-50%);
				border: 5px solid transparent;
				border-top-color: rgba(232, 255, 0, 0.3);
			}
			.leak-warning:hover .leak-tooltip {
				opacity: 1;
				visibility: visible;
			}
			@media (max-width: 768px) {
				.leak-flow {
					flex-direction: column;
					align-items: center;
					gap: 0;
				}
				.leak-station {
					width: 100%;
					max-width: 280px;
				}
				.leak-arrow {
					margin-top: 0;
					padding: 6px 0;
					flex-direction: row;
					gap: 6px;
				}
				.leak-arrow-line {
					width: 1px;
					height: 20px;
					background: linear-gradient(180deg, rgba(0, 255, 136, 0.3), rgba(0, 255, 136, 0.1));
				}
			}

			/* === UHL Method Cards === */
			.uhl-method-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
			}
			@media (max-width: 768px) {
				.uhl-method-grid { grid-template-columns: 1fr; }
			}
			.uhl-method-card {
				position: relative;
				overflow: hidden;
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 48px 32px 40px;
				transition: all 0.4s ease;
				opacity: 0;
				transform: translateY(40px);
			}
			.uhl-method-card.visible {
				opacity: 1;
				transform: translateY(0);
			}
			.uhl-method-card:hover {
				border-color: rgba(0, 255, 136, 0.35);
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.08);
				background: var(--color-bg3);
			}
			.uhl-watermark {
				position: absolute;
				top: -20px;
				right: -10px;
				font-size: 180px;
				font-weight: 900;
				font-family: var(--font-display);
				color: rgba(0, 255, 136, 0.04);
				line-height: 1;
				pointer-events: none;
				user-select: none;
			}
			.uhl-method-letter {
				font-size: 28px;
				font-weight: 700;
				color: var(--color-accent);
				font-family: var(--font-display);
				position: relative;
			}
			.uhl-method-title {
				font-size: 20px;
				font-weight: 600;
				color: var(--color-text);
				margin-top: 12px;
				position: relative;
			}
			/* === About Section === */
			@media (max-width: 767px) {
				.about-photo { max-height: 400px !important; }
				.about-photo-wrapper { transform: rotate(0deg) !important; }
			}
			.about-text-col {
				opacity: 0;
				transform: translateX(40px);
				transition: opacity 0.8s ease, transform 0.8s ease;
			}
			.about-text-col.visible {
				opacity: 1;
				transform: translateX(0);
			}
			.about-photo-col {
				opacity: 0;
				transform: translateY(30px);
				transition: opacity 0.7s ease, transform 0.7s ease;
			}
			.about-photo-col.visible {
				opacity: 1;
				transform: translateY(0);
			}

			.uhl-method-desc {
				font-size: 15px;
				color: var(--color-muted);
				line-height: 1.7;
				margin-top: 12px;
				position: relative;
			}
		</style>
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="relative overflow-hidden px-6 py-28 md:py-40">
			<div class="content-width text-center">
				<p class="fade-in mb-8 font-mono text-sm tracking-widest text-accent uppercase">Revenue Systems Architecture</p>
				<h1 class="hero-headline fade-in fade-in-delay-1 font-display font-bold text-text">
					Unlock Hidden Leverage.
				</h1>
				<p class="fade-in fade-in-delay-2 mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-muted">
					Most businesses optimize fragments. We architect the complete revenue system - from first click to lifetime value.
				</p>
				<div class="fade-in fade-in-delay-3 mt-14 flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a href="#contact" class="cta-primary inline-flex items-center gap-2">
						Find Your Revenue Leaks
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
					<a href="#method" class="cta-ghost inline-flex items-center gap-2">
						See the Method
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</div>
			<!-- Background grid effect -->
			<div class="pointer-events-none absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0); background-size: 40px 40px;"></div>
			<div class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full" style="background: radial-gradient(circle, rgba(0,255,136,0.05) 0%, transparent 70%);"></div>
		</section>

		<RevenueMuncher />

		<!-- Credibility Bar -->
		<section class="credibility-bar">
			<div class="credibility-grid">
				<div class="credibility-item">
					<span class="credibility-number">50%</span>
					<span class="credibility-label">Cost Reduction</span>
				</div>
				<div class="credibility-divider"></div>
				<div class="credibility-item">
					<span class="credibility-number">2x</span>
					<span class="credibility-label">Revenue Growth</span>
				</div>
				<div class="credibility-divider"></div>
				<div class="credibility-item">
					<span class="credibility-number">7</span>
					<span class="credibility-label">Revenue Leak Checkpoints</span>
				</div>
				<div class="credibility-divider"></div>
				<div class="credibility-item">
					<span class="credibility-number">4</span>
					<span class="credibility-label">Digital Products</span>
				</div>
			</div>
		</section>

		<!-- Ways to Work Together -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<p class="mb-4 text-center font-mono text-sm tracking-widest text-accent uppercase">Ways to Work Together</p>
				<h2 class="section-heading mb-16 text-center font-display font-bold text-text">
					Pick your starting point.
				</h2>

				<div class="grid gap-6 md:grid-cols-3">
					<div class="ways-card">
						<p class="mb-2 font-mono text-xs tracking-wider text-muted-dark uppercase">Tier 1</p>
						<h3 class="mb-2 text-lg font-semibold text-text">Revenue Leak Audit</h3>
						<p class="mb-4 text-[15px] leading-relaxed text-muted">Identify where you are losing money.</p>
						<div class="mt-auto">
							<div class="ways-price mb-4">1k &ndash; 2k EUR</div>
							<a href="/services/audit" class="cta-ghost block w-full text-center">Book Audit</a>
						</div>
					</div>

					<div class="ways-card" style="border-color: rgba(0, 255, 136, 0.3);">
						<p class="mb-2 font-mono text-xs tracking-wider text-muted-dark uppercase">Tier 2</p>
						<h3 class="mb-2 text-lg font-semibold text-text">Revenue Systems Consulting</h3>
						<p class="mb-4 text-[15px] leading-relaxed text-muted">Fix the leaks, build the system.</p>
						<div class="mt-auto">
							<div class="ways-price mb-4">3k &ndash; 6k EUR</div>
							<a href="/services/consulting" class="cta-ghost block w-full text-center">Book Consultation</a>
						</div>
					</div>

					<div class="ways-card">
						<p class="mb-2 font-mono text-xs tracking-wider text-muted-dark uppercase">Tier 3</p>
						<h3 class="mb-2 text-lg font-semibold text-text">Revenue Systems Partner</h3>
						<p class="mb-4 text-[15px] leading-relaxed text-muted">Ongoing execution partner.</p>
						<div class="mt-auto">
							<div class="ways-price mb-4">7k &ndash; 20k EUR</div>
							<a href={brand.calendly.en} class="cta-ghost block w-full text-center">Apply</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Revenue Leak Map -->
		<section class="border-t border-border px-6 py-28">
			<div class="content-width">
				<p class="mb-4 text-center font-mono text-sm tracking-widest text-accent uppercase">The Revenue Leak Map</p>
				<h2 class="section-heading mb-6 text-center font-display font-bold text-text">
					Where is your revenue leaking?
				</h2>
				<p class="mx-auto mb-20 max-w-2xl text-center text-muted">
					Every business has a revenue pipeline. Most have gaps they can't see. We map the full flow and find the leaks.
				</p>

				<div class="leak-flow">
					<!-- 01 Traffic Acquisition -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 19V5"/><path d="m5 12 7-7 7 7"/>
								</svg>
							</div>
							<div class="leak-number">01</div>
							<div class="leak-title">Traffic Acquisition</div>
							<div class="leak-hover-desc">Wrong audience, wasted spend</div>
						</div>
					</div>

					<div class="leak-arrow">
						<div class="leak-arrow-line"></div>
						<div class="leak-warning">
							<svg class="leak-stage-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12 7 2l5 10-5 10z"/><path d="M12 12l5-10 5 10-5 10z"/></svg>
							<div class="leak-tooltip">You attract visitors — but are they the right ones?</div>
						</div>
					</div>

					<!-- 02 Offer Positioning -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
								</svg>
							</div>
							<div class="leak-number">02</div>
							<div class="leak-title">Offer Positioning</div>
							<div class="leak-hover-desc">Weak positioning, no urgency</div>
						</div>
					</div>

					<div class="leak-arrow">
						<div class="leak-arrow-line"></div>
						<div class="leak-warning">
							<svg class="leak-stage-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
							<div class="leak-tooltip">Your offer exists — but does it connect to your traffic?</div>
						</div>
					</div>

					<!-- 03 Funnel Journey -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/>
								</svg>
							</div>
							<div class="leak-number">03</div>
							<div class="leak-title">Funnel Journey</div>
							<div class="leak-hover-desc">Friction kills conversions</div>
						</div>
					</div>

					<div class="leak-arrow">
						<div class="leak-arrow-line"></div>
						<div class="leak-warning">
							<svg class="leak-stage-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/></svg>
							<div class="leak-tooltip">People enter — but where do they drop off?</div>
						</div>
					</div>

					<!-- 04 Conversion Action -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
