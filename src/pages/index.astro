					<a href={brand.calendly.en} class="cta-primary block w-full max-w-sm text-center sm:inline-block sm:w-auto">
						Book Free Discovery Call
					</a>
				</div>
			</div>
		</section>

		<!-- Newsletter Opt-In -->
		<section class="border-t border-border bg-[#0a0a0a] px-6 py-20">
			<div class="mx-auto max-w-xl text-center">
				<h2 class="mb-3 font-display text-2xl font-bold text-text md:text-3xl">
					Get the Revenue Leak Map - Free
				</h2>
				<p class="mb-8 text-muted">
					Weekly insights on fixing revenue leaks. No fluff. Unsubscribe anytime.
				</p>
				<form id="newsletter-form" class="flex flex-col gap-3 sm:flex-row">
					<input
						type="email"
						required
						placeholder="email@example.com"
						class="flex-1 rounded-full border border-border bg-bg2 px-5 py-3 text-text placeholder-muted-dark outline-none transition-colors focus:border-accent"
					/>
					<button type="submit" class="cta-primary whitespace-nowrap">
						Subscribe →
					</button>
				</form>
				<p id="newsletter-thanks" class="mt-4 hidden text-sm font-medium text-accent">
					Thanks! Check your inbox.
				</p>
				<p class="mt-4 text-xs text-muted-dark">
					Join 0+ operators building better systems. Free guide included with every signup.
				</p>
			</div>
		</section>

		<Footer />

		<script>
			// === UHL Method Cards: Scroll-in Animation ===
			(function() {
				var cards = document.querySelectorAll('[data-uhl-card]');
				if (!cards.length) return;
				var observer = new IntersectionObserver(function(entries) {
					entries.forEach(function(entry) {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
							observer.unobserve(entry.target);
						}
					});
				}, { threshold: 0.15 });
				cards.forEach(function(card) { observer.observe(card); });
			})();

			// === About Section: Scroll Reveal ===
		(function() {
			var aboutEls = document.querySelectorAll('.about-text-col, .about-photo-col');
			if (!aboutEls.length) return;
			var observer = new IntersectionObserver(function(entries) {
				entries.forEach(function(entry) {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.15 });
			aboutEls.forEach(function(el) { observer.observe(el); });
		})();

		// === Revenue Leak Calculator ===
		(function() {
			var traffic = document.getElementById('calc-traffic');
			var cr = document.getElementById('calc-cr');
			var aov = document.getElementById('calc-aov');
			var email = document.getElementById('calc-email');
			if (!traffic || !cr || !aov) return;

			function fmt(n) {
				return '€' + Math.round(n).toLocaleString('en-US');
			}

			function calc() {
				var t = parseInt(traffic.value) || 0;
				var c = (parseInt(cr.value) || 0) / 10000; // slider value is basis points * 100
				var a = parseFloat(aov.value) || 0;

				document.getElementById('calc-traffic-val').textContent = t.toLocaleString('en-US');
				document.getElementById('calc-cr-val').textContent = (c * 100).toFixed(1) + '%';

				var current = t * c * a;
				var improved = t * (c + 0.005) * a;
				var leak = improved - current;

				document.getElementById('calc-current').textContent = fmt(current);
				document.getElementById('calc-potential').textContent = fmt(improved);
				document.getElementById('calc-leak').textContent = fmt(leak) + '/mo';
			}

			traffic.addEventListener('input', calc);
			cr.addEventListener('input', calc);
			aov.addEventListener('input', calc);
			email.addEventListener('input', calc);
			calc();
		})();

		// === Newsletter Form ===
			(function() {
				var form = document.getElementById('newsletter-form');
				if (!form) return;
				form.addEventListener('submit', function(e) {
					e.preventDefault();
					form.style.display = 'none';
					document.getElementById('newsletter-thanks').classList.remove('hidden');
				});
			})();
		</script>
	</body>
</html>
