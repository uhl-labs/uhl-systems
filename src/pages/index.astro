---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} - Unlock Hidden Leverage`} description={SITE_DESCRIPTION} isHomepage={true} />
		<style>
			.hero-headline {
				font-size: clamp(48px, 8vw, 96px);
				line-height: 1.05;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(32px, 5vw, 56px);
				line-height: 1.1;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 14px 36px;
				font-weight: 600;
				transition: all 0.2s;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.cta-ghost {
				border: 1px solid var(--color-border);
				border-radius: 999px;
				padding: 14px 36px;
				color: var(--color-muted);
				transition: all 0.2s;
			}
			.cta-ghost:hover {
				border-color: var(--color-accent);
				color: var(--color-text);
			}
			.uhl-card {
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 40px 32px;
				transition: all 0.3s;
			}
			.uhl-card:hover {
				border-color: rgba(0, 255, 136, 0.25);
				background: var(--color-bg3);
			}
			.content-width {
				max-width: 1100px;
				margin: 0 auto;
			}

			/* === Stats Bar === */
			.stats-bar {
				border-top: 1px solid var(--color-border);
				border-bottom: 1px solid var(--color-border);
				background: #111;
			}
			.stats-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
				text-align: center;
				padding: 3.5rem 1.5rem;
				max-width: 900px;
				margin: 0 auto;
			}
			.stat-number {
				font-size: clamp(48px, 6vw, 72px);
				font-weight: 800;
				color: var(--color-accent);
				line-height: 1;
				font-family: var(--font-display);
			}
			.stat-label {
				margin-top: 0.75rem;
				font-size: 14px;
				color: var(--color-muted);
				line-height: 1.4;
			}
			@media (max-width: 640px) {
				.stats-grid { grid-template-columns: 1fr; gap: 2.5rem; }
			}

			/* === Revenue Leak Map === */
			.leak-flow {
				display: flex;
				align-items: flex-start;
				gap: 0;
				overflow-x: auto;
				padding-bottom: 1rem;
			}
			.leak-station {
				flex: 1;
				min-width: 120px;
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				position: relative;
			}
			.leak-card {
				border: 1px solid #1a1a1a;
				background: var(--color-bg2);
				border-radius: 14px;
				padding: 20px 12px 16px;
				transition: all 0.35s ease;
				width: 100%;
				cursor: default;
			}
			.leak-card:hover {
				border-color: #00ff88;
				box-shadow: 0 0 24px rgba(0, 255, 136, 0.15), 0 0 48px rgba(0, 255, 136, 0.05);
				background: var(--color-bg3);
			}
			.leak-card:hover .leak-icon-wrap {
				background: rgba(0, 255, 136, 0.12);
			}
			.leak-card:hover .leak-hover-desc {
				opacity: 1;
				transform: translateY(0);
			}
			.leak-icon-wrap {
				width: 44px;
				height: 44px;
				border-radius: 10px;
				background: var(--color-bg3);
				display: flex;
				align-items: center;
				justify-content: center;
				margin: 0 auto 10px;
				transition: background 0.3s;
			}
			.leak-number {
				font-family: var(--font-mono);
				font-size: 10px;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--color-muted-dark);
			}
			.leak-title {
				font-size: 13px;
				font-weight: 600;
				color: var(--color-text);
				margin-top: 4px;
				line-height: 1.3;
			}
			.leak-hover-desc {
				font-size: 11px;
				color: var(--color-muted-dark);
				margin-top: 8px;
				line-height: 1.4;
				opacity: 0;
				transform: translateY(4px);
				transition: all 0.3s;
			}
			.leak-arrow {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				padding: 0 2px;
				flex-shrink: 0;
				margin-top: 30px;
			}
			.leak-arrow-line {
				width: 24px;
				height: 1px;
				background: linear-gradient(90deg, rgba(0, 255, 136, 0.3), rgba(0, 255, 136, 0.1));
			}
			.leak-warning {
				display: flex;
				align-items: center;
				gap: 2px;
				margin-top: 4px;
				font-size: 9px;
				font-family: var(--font-mono);
				color: #ff6b35;
				letter-spacing: 0.05em;
				white-space: nowrap;
			}
			.leak-warning-icon {
				width: 10px;
				height: 10px;
				flex-shrink: 0;
			}
			@media (max-width: 768px) {
				.leak-flow {
					flex-direction: column;
					align-items: center;
					gap: 0;
				}
				.leak-station {
					width: 100%;
					max-width: 280px;
				}
				.leak-arrow {
					margin-top: 0;
					padding: 6px 0;
					flex-direction: row;
					gap: 6px;
				}
				.leak-arrow-line {
					width: 1px;
					height: 20px;
					background: linear-gradient(180deg, rgba(0, 255, 136, 0.3), rgba(0, 255, 136, 0.1));
				}
			}

			/* === UHL Method Cards === */
			.uhl-method-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
			}
			@media (max-width: 768px) {
				.uhl-method-grid { grid-template-columns: 1fr; }
			}
			.uhl-method-card {
				position: relative;
				overflow: hidden;
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 48px 32px 40px;
				transition: all 0.4s ease;
				opacity: 0;
				transform: translateY(40px);
			}
			.uhl-method-card.visible {
				opacity: 1;
				transform: translateY(0);
			}
			.uhl-method-card:hover {
				border-color: rgba(0, 255, 136, 0.35);
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.08);
				background: var(--color-bg3);
			}
			.uhl-watermark {
				position: absolute;
				top: -20px;
				right: -10px;
				font-size: 180px;
				font-weight: 900;
				font-family: var(--font-display);
				color: rgba(0, 255, 136, 0.04);
				line-height: 1;
				pointer-events: none;
				user-select: none;
			}
			.uhl-method-letter {
				font-size: 28px;
				font-weight: 700;
				color: var(--color-accent);
				font-family: var(--font-display);
				position: relative;
			}
			.uhl-method-title {
				font-size: 20px;
				font-weight: 600;
				color: var(--color-text);
				margin-top: 12px;
				position: relative;
			}
			.uhl-method-desc {
				font-size: 15px;
				color: var(--color-muted);
				line-height: 1.7;
				margin-top: 12px;
				position: relative;
			}
		</style>
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="relative overflow-hidden px-6 py-28 md:py-40">
			<div class="content-width text-center">
				<p class="fade-in mb-8 font-mono text-sm tracking-widest text-accent uppercase">Revenue Systems Architecture</p>
				<h1 class="hero-headline fade-in fade-in-delay-1 font-display font-bold text-text">
					Unlock Hidden Leverage.
				</h1>
				<p class="fade-in fade-in-delay-2 mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-muted">
					Most businesses optimize fragments. We architect the complete revenue system - from first click to lifetime value.
				</p>
				<div class="fade-in fade-in-delay-3 mt-14 flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a href="#contact" class="cta-primary inline-flex items-center gap-2">
						Find Your Revenue Leaks
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
					<a href="#method" class="cta-ghost inline-flex items-center gap-2">
						See the Method
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</div>
			<!-- Background grid effect -->
			<div class="pointer-events-none absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0); background-size: 40px 40px;"></div>
			<div class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full" style="background: radial-gradient(circle, rgba(0,255,136,0.05) 0%, transparent 70%);"></div>
		</section>

		<!-- Stats Bar -->
		<section class="stats-bar" data-stats>
			<div class="stats-grid">
				<div>
					<div class="stat-number" data-count="7">0</div>
					<div class="stat-label">Revenue Leak Types We Fix</div>
				</div>
				<div>
					<div class="stat-number" data-count="90">0</div>
					<div class="stat-label">Days to Transform Your System</div>
				</div>
				<div>
					<div class="stat-number" data-count="0">0</div>
					<div class="stat-label">Extra Ad Spend Required</div>
				</div>
			</div>
		</section>

		<!-- Revenue Leak Map -->
		<section class="border-t border-border px-6 py-28">
			<div class="content-width">
				<p class="mb-4 text-center font-mono text-sm tracking-widest text-accent uppercase">The Revenue Leak Map</p>
				<h2 class="section-heading mb-6 text-center font-display font-bold text-text">
					Where is your revenue leaking?
				</h2>
				<p class="mx-auto mb-20 max-w-2xl text-center text-muted">
					Every business has a revenue pipeline. Most have gaps they can't see. We map the full flow and find the leaks.
				</p>

				<div class="leak-flow">
					<!-- 01 Traffic Acquisition -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 19V5"/><path d="m5 12 7-7 7 7"/>
								</svg>
							</div>
							<div class="leak-number">01</div>
							<div class="leak-title">Traffic Acquisition</div>
							<div class="leak-hover-desc">Wrong audience, wasted spend</div>
						</div>
					</div>

					<div class="leak-arrow">
						<div class="leak-arrow-line"></div>
						<div class="leak-warning">
							<svg class="leak-warning-icon" viewBox="0 0 24 24" fill="none" stroke="#ff6b35" stroke-width="2"><path d="M12 2L2 22h20L12 2z"/><path d="M12 10v4"/><circle cx="12" cy="18" r="0.5" fill="#ff6b35"/></svg>
							Leak?
						</div>
					</div>

					<!-- 02 Offer Positioning -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
								</svg>
							</div>
							<div class="leak-number">02</div>
							<div class="leak-title">Offer Positioning</div>
							<div class="leak-hover-desc">Weak positioning, no urgency</div>
						</div>
					</div>

					<div class="leak-arrow">
						<div class="leak-arrow-line"></div>
						<div class="leak-warning">
							<svg class="leak-warning-icon" viewBox="0 0 24 24" fill="none" stroke="#ff6b35" stroke-width="2"><path d="M12 2L2 22h20L12 2z"/><path d="M12 10v4"/><circle cx="12" cy="18" r="0.5" fill="#ff6b35"/></svg>
							Leak?
						</div>
					</div>

					<!-- 03 Funnel Journey -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/>
								</svg>
							</div>
							<div class="leak-number">03</div>
							<div class="leak-title">Funnel Journey</div>
							<div class="leak-hover-desc">Friction kills conversions</div>
						</div>
					</div>

					<div class="leak-arrow">
						<div class="leak-arrow-line"></div>
						<div class="leak-warning">
							<svg class="leak-warning-icon" viewBox="0 0 24 24" fill="none" stroke="#ff6b35" stroke-width="2"><path d="M12 2L2 22h20L12 2z"/><path d="M12 10v4"/><circle cx="12" cy="18" r="0.5" fill="#ff6b35"/></svg>
							Leak?
						</div>
					</div>

					<!-- 04 Conversion Action -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M9 3h6l3 7-7.5 11L3 10z"/><path d="m14 8-3 5"/>
								</svg>
							</div>
							<div class="leak-number">04</div>
							<div class="leak-title">Conversion Action</div>
							<div class="leak-hover-desc">No trust, no proof, no sale</div>
						</div>
					</div>

					<div class="leak-arrow">
						<div class="leak-arrow-line"></div>
						<div class="leak-warning">
							<svg class="leak-warning-icon" viewBox="0 0 24 24" fill="none" stroke="#ff6b35" stroke-width="2"><path d="M12 2L2 22h20L12 2z"/><path d="M12 10v4"/><circle cx="12" cy="18" r="0.5" fill="#ff6b35"/></svg>
							Leak?
						</div>
					</div>

					<!-- 05 Monetization -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
								</svg>
							</div>
							<div class="leak-number">05</div>
							<div class="leak-title">Monetization</div>
							<div class="leak-hover-desc">Underpriced, no upsells</div>
						</div>
					</div>

					<div class="leak-arrow">
						<div class="leak-arrow-line"></div>
						<div class="leak-warning">
							<svg class="leak-warning-icon" viewBox="0 0 24 24" fill="none" stroke="#ff6b35" stroke-width="2"><path d="M12 2L2 22h20L12 2z"/><path d="M12 10v4"/><circle cx="12" cy="18" r="0.5" fill="#ff6b35"/></svg>
							Leak?
						</div>
					</div>

					<!-- 06 Retention -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M21 12a9 9 0 1 1-9-9"/><path d="M21 3v9h-9"/>
								</svg>
							</div>
							<div class="leak-number">06</div>
							<div class="leak-title">Retention</div>
							<div class="leak-hover-desc">Churn erodes everything</div>
						</div>
					</div>

					<div class="leak-arrow">
						<div class="leak-arrow-line"></div>
						<div class="leak-warning">
							<svg class="leak-warning-icon" viewBox="0 0 24 24" fill="none" stroke="#ff6b35" stroke-width="2"><path d="M12 2L2 22h20L12 2z"/><path d="M12 10v4"/><circle cx="12" cy="18" r="0.5" fill="#ff6b35"/></svg>
							Leak?
						</div>
					</div>

					<!-- 07 LTV Growth -->
					<div class="leak-station">
						<div class="leak-card">
							<div class="leak-icon-wrap">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M2 20h.01"/><path d="M7 20v-4"/><path d="M12 20v-8"/><path d="M17 20V8"/><path d="M22 4v16"/>
								</svg>
							</div>
							<div class="leak-number">07</div>
							<div class="leak-title">LTV Growth</div>
							<div class="leak-hover-desc">No compounding, no growth</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- The UHL Method -->
		<section id="method" class="border-t border-border px-6 py-28">
			<div class="content-width">
				<p class="mb-4 text-center font-mono text-sm tracking-widest text-accent uppercase">The Method</p>
				<h2 class="section-heading mb-6 text-center font-display font-bold text-text">
					U &ndash; H &ndash; L
				</h2>
				<p class="mx-auto mb-20 max-w-xl text-center text-muted">
					Unlock Hidden Leverage. Three phases. One system. Compounding results.
				</p>

				<div class="uhl-method-grid">
					<div class="uhl-method-card" data-uhl-card>
						<div class="uhl-watermark">U</div>
						<div class="uhl-method-letter">U</div>
						<div class="uhl-method-title">Uncover Revenue Leaks</div>
						<div class="uhl-method-desc">
							Deep audit of your current system. We map every touchpoint, identify every leak, and quantify the revenue left on the table.
						</div>
					</div>

					<div class="uhl-method-card" data-uhl-card style="transition-delay: 0.12s;">
						<div class="uhl-watermark">H</div>
						<div class="uhl-method-letter">H</div>
						<div class="uhl-method-title">Hack Conversion Systems</div>
						<div class="uhl-method-desc">
							Data-driven strategy design. We build your revenue architecture with clear priorities, timelines, and expected impact per lever.
						</div>
					</div>

					<div class="uhl-method-card" data-uhl-card style="transition-delay: 0.24s;">
						<div class="uhl-watermark">L</div>
						<div class="uhl-method-letter">L</div>
						<div class="uhl-method-title">Leverage Existing Traffic</div>
						<div class="uhl-method-desc">
							Systematic execution. We build, test, and optimize each component of your revenue system until it compounds.
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Offer Tiers -->
		<section class="border-t border-border px-6 py-28">
			<div class="content-width">
				<p class="mb-4 text-center font-mono text-sm tracking-widest text-accent uppercase">Work With Us</p>
				<h2 class="section-heading mb-20 text-center font-display font-bold text-text">
					Choose your level
				</h2>

				<div class="grid gap-6 md:grid-cols-3">
					<!-- Audit -->
					<div class="uhl-card group flex flex-col">
						<div class="mb-6">
							<div class="mb-1 flex items-center gap-2">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
								<h3 class="text-lg font-semibold text-text">The Audit</h3>
							</div>
							<p class="font-mono text-xs tracking-wider text-muted-dark uppercase">Revenue Leak Analysis</p>
						</div>
						<p class="mb-6 text-[15px] leading-relaxed text-muted">
							Complete diagnostic of your revenue system. You get a prioritized map of leaks, quick wins, and a roadmap for fixing them. Option to continue working together afterwards - no obligation.
						</p>
