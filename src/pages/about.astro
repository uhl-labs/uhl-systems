---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — Lukas Uhl | UHL Systems" description="Meet Lukas Uhl — Revenue Systems Architect, builder, and the person behind UHL Systems." />
		<style>
			@media (max-width: 767px) {
				.about-photo { max-height: 400px !important; }
				.about-photo-wrapper { transform: rotate(0deg) !important; }
			}
			.about-text-col {
				opacity: 0;
				transform: translateX(40px);
				transition: opacity 0.8s ease, transform 0.8s ease;
			}
			.about-text-col.visible {
				opacity: 1;
				transform: translateX(0);
			}
			.about-photo-col {
				opacity: 0;
				transform: translateY(30px);
				transition: opacity 0.7s ease, transform 0.7s ease;
			}
			.about-photo-col.visible {
				opacity: 1;
				transform: translateY(0);
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 14px 36px;
				font-weight: 600;
				transition: all 0.2s;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
		</style>
	</head>
	<body>
		<Header />

		<section class="relative overflow-hidden" style="background: #0d0d0d;">
			<div class="mx-auto grid max-w-6xl items-center gap-0 px-6 py-32 md:grid-cols-2 md:gap-16 md:py-40">
				<!-- Photo column -->
				<div class="about-photo-col relative mb-12 flex justify-center md:mb-0">
					<div class="about-photo-wrapper relative" style="transform: rotate(-2deg);">
						<span class="absolute left-4 top-4 z-10 rounded bg-accent/90 px-2 py-1 font-mono text-[10px] font-bold tracking-widest text-bg uppercase">Founder</span>
						<img
							src="/lukas.jpg"
							alt="Lukas Uhl"
							class="about-photo relative z-[1] block w-full max-w-[480px] rounded-2xl object-cover object-top shadow-2xl"
							style="max-height: 600px; border: 2px solid transparent; border-image: linear-gradient(180deg, rgba(0,255,136,0.5), transparent) 1;"
						/>
						<div class="pointer-events-none absolute -bottom-4 -right-4 z-0 h-full w-full rounded-2xl" style="background: linear-gradient(135deg, rgba(0,255,136,0.08), transparent 60%);"></div>
					</div>
				</div>
				<!-- Text column -->
				<div class="about-text-col">
					<p class="mb-4 font-mono text-sm tracking-widest text-accent uppercase">The Person Behind UHL</p>
					<h1 class="font-display text-5xl font-bold tracking-tight text-text md:text-7xl">Lukas Uhl</h1>
					<p class="mt-3 text-lg font-medium tracking-wide text-muted md:text-xl">Revenue Systems Architect. Builder. Operator.</p>
					<div class="mt-8 space-y-4 text-[15px] leading-relaxed text-muted md:text-base md:leading-relaxed">
						<p>I started UHL because I kept seeing the same problem: smart people with great businesses, hemorrhaging revenue through invisible leaks.</p>
						<p>Not because they lacked ambition — but because they were optimizing fragments instead of systems.</p>
						<p>My background spans marketing, sales engineering, software, and AI. I combine all of it to build revenue systems that compound — not just campaigns that spike.</p>
						<p>Based in Germany. Building globally.</p>
					</div>
					<p class="mt-6 font-mono text-xs tracking-wide text-muted-dark">31 years old &bull; Aquarius &#9811; &bull; Currently: Building UHL Labs</p>
					<a href="https://calendly.com/uhl-systems/30min?redirect_url=https://uhl-systems.com/booking-confirmed" class="cta-primary mt-10 inline-flex items-center gap-2">
						Let's talk about your system
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</div>
			<div class="pointer-events-none absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.015) 1px, transparent 0); background-size: 32px 32px;"></div>
		</section>

		<Footer />

		<script>
			(function() {
				var aboutEls = document.querySelectorAll('.about-text-col, .about-photo-col');
				if (!aboutEls.length) return;
				var observer = new IntersectionObserver(function(entries) {
					entries.forEach(function(entry) {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
							observer.unobserve(entry.target);
						}
					});
				}, { threshold: 0.15 });
				aboutEls.forEach(function(el) { observer.observe(el); });
			})();
		</script>
	</body>
</html>
