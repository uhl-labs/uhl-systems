---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { brand } from '../../config/brand';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="What Happens When You Join | UHL Systems" description="No guesswork. No vague deliverables. This is the exact 3-phase process behind our Revenue Systems Consulting." />
		<style>
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.content-width {
				max-width: 900px;
				margin: 0 auto;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 14px 36px;
				font-weight: 600;
				transition: all 0.2s;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}

			/* Timeline */
			.timeline {
				position: relative;
				padding-left: 0;
			}
			@media (min-width: 768px) {
				.timeline {
					padding-left: 80px;
				}
			}
			.timeline::before {
				content: '';
				position: absolute;
				left: 31px;
				top: 0;
				bottom: 0;
				width: 2px;
				background: linear-gradient(to bottom, var(--color-accent), rgba(0, 255, 136, 0.1));
				display: none;
			}
			@media (min-width: 768px) {
				.timeline::before {
					display: block;
				}
			}
			.phase-card {
				position: relative;
				border: 1px solid var(--color-border);
				background: var(--color-bg2);
				border-radius: 16px;
				padding: 40px 32px;
				transition: all 0.3s;
			}
			.phase-card:hover {
				border-color: rgba(0, 255, 136, 0.25);
				background: var(--color-bg3);
			}
			.phase-number {
				width: 48px;
				height: 48px;
				border-radius: 50%;
				border: 2px solid var(--color-accent);
				background: var(--color-bg);
				display: flex;
				align-items: center;
				justify-content: center;
				font-family: var(--font-display);
				font-weight: 800;
				font-size: 20px;
				color: var(--color-accent);
				flex-shrink: 0;
			}
			@media (min-width: 768px) {
				.phase-number {
					position: absolute;
					left: -80px;
					top: 40px;
					width: 56px;
					height: 56px;
					font-size: 22px;
				}
			}
			.phase-bullet {
				position: relative;
				padding-left: 20px;
				color: var(--color-muted);
				font-size: 15px;
				line-height: 1.7;
			}
			.phase-bullet::before {
				content: '';
				position: absolute;
				left: 0;
				top: 10px;
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--color-accent);
			}
			.deliverable {
				border-top: 1px solid var(--color-border);
				margin-top: 20px;
				padding-top: 16px;
				color: var(--color-text);
				font-weight: 500;
				font-size: 15px;
			}
			.deliverable span {
				color: var(--color-accent);
				font-weight: 700;
				margin-right: 6px;
			}
			.guarantee-card {
				border: 1px solid rgba(0, 255, 136, 0.2);
				background: rgba(0, 255, 136, 0.03);
				border-radius: 16px;
				padding: 40px 32px;
			}
		</style>
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="relative overflow-hidden px-6 py-24 md:py-36">
			<div class="content-width text-center">
				<p class="fade-in mb-6 font-mono text-sm tracking-widest text-accent uppercase">Revenue Systems Consulting</p>
				<h1 class="hero-headline fade-in fade-in-delay-1 font-display font-bold text-text">
					Here is what happens when you join.
				</h1>
				<p class="fade-in fade-in-delay-2 mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-muted">
					No guesswork. No vague deliverables. This is the exact process.
				</p>
			</div>
			<div class="pointer-events-none absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0); background-size: 40px 40px;"></div>
			<div class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full" style="background: radial-gradient(circle, rgba(0,255,136,0.05) 0%, transparent 70%);"></div>
		</section>

		<!-- Timeline -->
		<section class="border-t border-border px-6 py-28">
			<div class="content-width">
				<div class="timeline space-y-10">

					<!-- Phase 1 -->
					<div class="phase-card fade-in">
						<div class="mb-6 flex items-center gap-4">
							<div class="phase-number">1</div>
							<div>
								<h2 class="text-2xl font-bold text-text font-display">Diagnose</h2>
								<p class="font-mono text-xs tracking-wider text-accent uppercase">Week 1-2</p>
							</div>
						</div>
						<div class="space-y-3">
							<p class="phase-bullet">90-Minute Revenue Leak Audit (deep dive into your system)</p>
							<p class="phase-bullet">Full Revenue Leak Map delivered (7 dimensions, quantified)</p>
							<p class="phase-bullet">Priority stack: which leaks cost you the most, in what order to fix them</p>
						</div>
						<div class="deliverable">
							<span>You get:</span> a document you can act on with or without us
						</div>
					</div>

					<!-- Phase 2 -->
					<div class="phase-card fade-in">
						<div class="mb-6 flex items-center gap-4">
							<div class="phase-number">2</div>
							<div>
								<h2 class="text-2xl font-bold text-text font-display">Architecture</h2>
								<p class="font-mono text-xs tracking-wider text-accent uppercase">Week 3-4</p>
							</div>
						</div>
						<div class="space-y-3">
							<p class="phase-bullet">Revenue system design: conversion flows, offer structure, monetization layers</p>
							<p class="phase-bullet">Implementation roadmap: what gets built, in what order, with what expected impact</p>
							<p class="phase-bullet">Tech stack decisions: which tools, which automations, which you never need</p>
						</div>
						<div class="deliverable">
							<span>You get:</span> a complete blueprint, ready to execute
						</div>
					</div>

					<!-- Phase 3 -->
					<div class="phase-card fade-in">
						<div class="mb-6 flex items-center gap-4">
							<div class="phase-number">3</div>
							<div>
								<h2 class="text-2xl font-bold text-text font-display">Execution</h2>
								<p class="font-mono text-xs tracking-wider text-accent uppercase">Week 5-12</p>
							</div>
						</div>
						<div class="space-y-3">
							<p class="phase-bullet">We build. You approve. Systems go live.</p>
							<p class="phase-bullet">Weekly check-ins: what shipped, what is next, what changed</p>
							<p class="phase-bullet">Iteration based on data, not gut feeling</p>
						</div>
						<div class="deliverable">
							<span>You get:</span> a running revenue system with measurable results
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- Guarantee -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<div class="guarantee-card text-center">
					<div class="mb-4 text-3xl">
						<svg class="mx-auto text-accent" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
					</div>
					<p class="mx-auto max-w-xl text-lg leading-relaxed text-muted">
						If after Phase 1 you feel this is not right for you - you pay only for the audit. No commitment beyond that.
					</p>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="border-t border-border px-6 py-28">
			<div class="content-width text-center">
				<p class="mb-4 font-mono text-sm tracking-widest text-accent uppercase">Ready?</p>
				<h2 class="mb-6 font-display text-3xl font-bold text-text md:text-4xl">
					Start with a Strategy Call
				</h2>
				<p class="mx-auto mb-14 max-w-xl text-muted">
					30 minutes. We assess where you are, what the biggest leaks are, and whether this is the right fit.
				</p>
				<div class="flex flex-col items-center gap-4">
					<a href={brand.strategyCall.checkoutUrl} class="cta-primary inline-flex items-center gap-2">
						Book Strategy Call - 97€
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
					<p class="font-mono text-xs text-muted">30 Min | 97€ | Applied to project if you move forward</p>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
