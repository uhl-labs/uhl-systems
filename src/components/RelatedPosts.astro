---
import FormattedDate from './FormattedDate.astro';

interface RelatedPost {
	id: string;
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: string;
	href: string;
}

interface Props {
	posts: RelatedPost[];
	lang?: 'en' | 'de';
}

const { posts, lang = 'en' } = Astro.props;
const heading = lang === 'de' ? 'Weitere Artikel' : 'Related Articles';
---

{posts.length > 0 && (
	<section class="mt-16 border-t border-border pt-12">
		<h2 class="mb-8 font-display text-2xl font-bold text-text">{heading}</h2>
		<div class="grid gap-6 md:grid-cols-3">
			{posts.map((post) => (
				<a
					href={post.href}
					class="group block rounded-xl border border-border bg-bg2 overflow-hidden transition-all duration-300 hover:border-accent/30 hover:bg-bg3 no-underline"
				>
					{post.heroImage && (
						<div class="overflow-hidden">
							<img
								src={post.heroImage}
								alt={post.title}
								class="w-full h-40 object-cover transition-transform duration-300 group-hover:scale-[1.02]"
								loading="lazy"
							/>
						</div>
					)}
					<div class="p-5">
						<p class="mb-2 font-mono text-xs text-muted-dark">
							<FormattedDate date={post.pubDate} />
						</p>
						<h3 class="text-base font-semibold text-text group-hover:text-accent transition-colors">
							{post.title}
						</h3>
						{post.description && (
							<p class="mt-2 text-sm text-muted line-clamp-2">{post.description}</p>
						)}
					</div>
				</a>
			))}
		</div>
	</section>
)}
