---
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-bg py-16">
	<div class="mx-auto max-w-6xl px-6">
		<div class="flex flex-col items-center gap-8 md:flex-row md:justify-between">
			<div class="text-center md:text-left">
				<div class="mb-2 flex items-center justify-center gap-2 md:justify-start">
					<span class="font-display text-lg font-bold tracking-tight text-text">UHL</span>
					<span class="text-sm font-light tracking-widest text-muted-dark uppercase">Systems</span>
				</div>
				<p class="text-sm text-muted-dark">Unlock Hidden Leverage.</p>
			</div>

			<div class="flex items-center gap-6">
				<a href="https://www.instagram.com/uhl.labs" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-muted transition-colors hover:text-accent">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
					@uhl.labs
				</a>
			</div>
		</div>

		<div class="mt-10 flex flex-col items-center gap-3 border-t border-border pt-6 text-center text-sm text-muted-dark">
			<div class="flex flex-wrap justify-center gap-4">
				<a href="/services" class="transition-colors hover:text-text">Services</a>
				<a href="/services/audit" class="transition-colors hover:text-text">Revenue Leak Audit</a>
				<a href="/services/consulting" class="transition-colors hover:text-text">Consulting</a>
				<a href="/shop" class="transition-colors hover:text-text">Shop</a>
				<a href="/blog" class="transition-colors hover:text-text">Blog</a>
			</div>
			<div class="flex flex-wrap justify-center gap-4">
				<a href="/impressum" class="transition-colors hover:text-text">Impressum</a>
				<a href="/privacy" class="transition-colors hover:text-text">Datenschutz</a>
				<a href="mailto:luke@uhl-systems.com" class="transition-colors hover:text-text">luke@uhl-systems.com</a>
			</div>
			<p>&copy; {year} UHL Labs &middot; uhl-systems.com</p>
		</div>
	</div>
</footer>
