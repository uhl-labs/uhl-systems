---
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-bg py-12">
	<div class="mx-auto max-w-6xl px-6 text-center">
		<div class="mb-4 flex items-center justify-center gap-2">
			<span class="font-display text-lg font-bold tracking-tight text-text">UHL</span>
			<span class="text-sm font-light tracking-widest text-muted-dark uppercase">Systems</span>
		</div>
		<p class="text-sm text-muted-dark">
			&copy; {year} UHL Systems. All rights reserved.
		</p>
	</div>
</footer>
