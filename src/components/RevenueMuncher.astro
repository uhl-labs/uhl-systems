---
interface Props {
	tagline?: string;
}
const { tagline = "We eat revenue leaks." } = Astro.props;
---

<div class="muncher-strip" data-muncher>
	<div class="muncher-track">
		<!-- Leak items that get eaten -->
		<div class="leak-item" style="left: 15%;">
			<svg width="18" height="18" viewBox="0 0 18 18" fill="none">
				<circle cx="9" cy="9" r="8" stroke="#00ff88" stroke-width="1.5" opacity="0.6"/>
				<text x="9" y="13" text-anchor="middle" fill="#00ff88" font-size="11" font-weight="600" opacity="0.7">€</text>
			</svg>
		</div>
		<div class="leak-item" style="left: 30%;">
			<svg width="14" height="14" viewBox="0 0 14 14" fill="none">
				<path d="M7 1 L7 13 M4 4 Q7 2 10 4 M4 7 Q7 5 10 7" stroke="#00ff88" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
			</svg>
		</div>
		<div class="leak-item" style="left: 45%;">
			<svg width="18" height="18" viewBox="0 0 18 18" fill="none">
				<circle cx="9" cy="9" r="8" stroke="#00ff88" stroke-width="1.5" opacity="0.6"/>
				<text x="9" y="13" text-anchor="middle" fill="#00ff88" font-size="11" font-weight="600" opacity="0.7">€</text>
			</svg>
		</div>
		<div class="leak-item" style="left: 58%;">
			<!-- Drip/leak drop -->
			<svg width="12" height="16" viewBox="0 0 12 16" fill="none">
				<path d="M6 1 Q6 8 2 12 Q6 15 10 12 Q6 8 6 1Z" fill="#00ff88" opacity="0.4"/>
			</svg>
		</div>
		<div class="leak-item" style="left: 72%;">
			<svg width="18" height="18" viewBox="0 0 18 18" fill="none">
				<circle cx="9" cy="9" r="8" stroke="#00ff88" stroke-width="1.5" opacity="0.6"/>
				<text x="9" y="13" text-anchor="middle" fill="#00ff88" font-size="11" font-weight="600" opacity="0.7">€</text>
			</svg>
		</div>
		<div class="leak-item" style="left: 85%;">
			<svg width="12" height="16" viewBox="0 0 12 16" fill="none">
				<path d="M6 1 Q6 8 2 12 Q6 15 10 12 Q6 8 6 1Z" fill="#00ff88" opacity="0.4"/>
			</svg>
		</div>

		<!-- The Muncher character -->
		<div class="muncher-character">
			<div class="muncher-body">
				<div class="muncher-eye"></div>
			</div>
		</div>
	</div>

	<p class="muncher-tagline">{tagline}</p>
</div>

<style>
	.muncher-strip {
		position: relative;
		width: 100%;
		height: 56px;
		overflow: hidden;
		background: var(--color-bg);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.muncher-track {
		position: relative;
		width: 100%;
		height: 40px;
		margin-top: 8px;
	}

	/* Leak items */
	.leak-item {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		opacity: 1;
		transition: opacity 0.15s ease-out, transform 0.15s ease-out;
	}
	.leak-item.eaten {
		opacity: 0;
		transform: translateY(-50%) scale(0.2);
	}

	/* Muncher character */
	.muncher-character {
		position: absolute;
		left: -40px;
		top: 50%;
		transform: translateY(-50%);
		width: 32px;
		height: 32px;
		z-index: 2;
	}

	.muncher-body {
		width: 32px;
		height: 32px;
		background: var(--color-accent, #00ff88);
		border-radius: 50%;
		position: relative;
		clip-path: polygon(
			100% 50%,
			/* mouth open */
			75% 15%,
			50% 0%,
			25% 0%,
			0% 15%,
			0% 50%,
			0% 85%,
			25% 100%,
			50% 100%,
			75% 85%,
			100% 50%
		);
		animation: munch 0.3s steps(2) infinite;
		box-shadow: 0 0 12px rgba(0, 255, 136, 0.3);
	}

	@keyframes munch {
		0% {
			clip-path: polygon(
				100% 50%,
				80% 25%,
				50% 0%,
				25% 0%,
				0% 15%,
				0% 50%,
				0% 85%,
				25% 100%,
				50% 100%,
				80% 75%,
				100% 50%
			);
		}
		50% {
			clip-path: polygon(
				100% 50%,
				90% 42%,
				50% 0%,
				25% 0%,
				0% 15%,
				0% 50%,
				0% 85%,
				25% 100%,
				50% 100%,
				90% 58%,
				100% 50%
			);
		}
		100% {
			clip-path: polygon(
				100% 50%,
				80% 25%,
				50% 0%,
				25% 0%,
				0% 15%,
				0% 50%,
				0% 85%,
				25% 100%,
				50% 100%,
				80% 75%,
				100% 50%
			);
		}
	}

	.muncher-eye {
		position: absolute;
		width: 6px;
		height: 6px;
		background: var(--color-bg, #080808);
		border-radius: 50%;
		top: 7px;
		right: 8px;
	}

	/* Tagline */
	.muncher-tagline {
		position: absolute;
		right: 20px;
		top: 50%;
		transform: translateY(-50%);
		font-family: var(--font-mono, 'Space Mono', monospace);
		font-size: 11px;
		letter-spacing: 0.08em;
		color: var(--color-muted, #888);
		opacity: 0;
		transition: opacity 0.6s ease 0.3s;
		text-transform: uppercase;
	}
	.muncher-strip.active .muncher-tagline {
		opacity: 1;
	}

	/* Responsive */
	@media (max-width: 640px) {
		.muncher-strip {
			height: 44px;
		}
		.muncher-track {
			height: 32px;
			margin-top: 6px;
		}
		.muncher-character {
			width: 24px;
			height: 24px;
		}
		.muncher-body {
			width: 24px;
			height: 24px;
		}
		.muncher-eye {
			width: 4px;
			height: 4px;
			top: 5px;
			right: 6px;
		}
		.muncher-tagline {
			font-size: 11px;
			right: 12px;
		}
	}
</style>

<script>
	function initMuncher() {
		const strip = document.querySelector<HTMLElement>('[data-muncher]');
		if (!strip) return;

		const character = strip.querySelector<HTMLElement>('.muncher-character');
		const leakItems = strip.querySelectorAll<HTMLElement>('.leak-item');
		if (!character) return;

		let hasRun = false;

		function runAnimation() {
			if (hasRun) return;
			hasRun = true;

			strip!.classList.add('active');
			const trackWidth = strip!.offsetWidth;
			const duration = 3000;
			const startTime = performance.now();

			// Collect leak positions
			const leakPositions = Array.from(leakItems).map((item) => {
				const pct = parseFloat(item.style.left) / 100;
				return { el: item, pos: pct * trackWidth, eaten: false };
			});

			function animate(now: number) {
				const elapsed = now - startTime;
				const progress = Math.min(elapsed / duration, 1);
				// Ease-in-out
				const eased = progress < 0.5
					? 2 * progress * progress
					: 1 - Math.pow(-2 * progress + 2, 2) / 2;

				const currentX = -40 + eased * (trackWidth + 60);
				character!.style.left = `${currentX}px`;

				// Eat leaks when muncher reaches them
				for (const leak of leakPositions) {
					if (!leak.eaten && currentX + 16 >= leak.pos) {
						leak.eaten = true;
						leak.el.classList.add('eaten');
					}
				}

				if (progress < 1) {
					requestAnimationFrame(animate);
				} else {
					// Done — allow re-run after delay
					setTimeout(() => {
						hasRun = false;
						// Reset items
						character!.style.left = '-40px';
						leakItems.forEach((item) => item.classList.remove('eaten'));
						strip!.classList.remove('active');
					}, 10000);
				}
			}

			requestAnimationFrame(animate);
		}

		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting && !hasRun) {
						runAnimation();
					}
				}
			},
			{ threshold: 0.5 }
		);

		observer.observe(strip);
	}

	// Run on page load and after Astro navigation
	document.addEventListener('astro:page-load', initMuncher);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initMuncher);
	} else {
		initMuncher();
	}
</script>
