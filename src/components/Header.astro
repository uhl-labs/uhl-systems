---
import HeaderLink from './HeaderLink.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith("/de");
const langSwitchHref = isDE ? "/" : "/de/";
const langSwitchLabel = isDE ? "EN" : "DE";
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
	<nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
		<a href="/" class="flex items-center gap-2 text-text no-underline hover:text-text">
			<span class="font-display text-lg font-bold tracking-tight">UHL</span>
			<span class="text-sm font-light tracking-widest text-muted uppercase">Systems</span>
		</a>
		<div class="flex items-center gap-8">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/services/audit">Services</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/shop">Shop</HeaderLink>
			<HeaderLink href="#contact">Contact</HeaderLink>
			<a href="https://www.instagram.com/uhl.labs" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-muted transition-colors hover:text-accent" aria-label="Instagram @uhl.labs">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
				<span class="hidden text-xs sm:inline">@uhl.labs</span>
			</a>
			<a href={langSwitchHref} class="rounded-full border border-border px-3 py-1 font-mono text-xs tracking-wider text-muted transition-all hover:border-accent hover:text-text">{langSwitchLabel}</a>
		</div>
	</nav>
</header>
<!-- Spacer for fixed header -->
<div class="h-16"></div>
