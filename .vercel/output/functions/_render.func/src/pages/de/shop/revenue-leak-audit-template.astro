---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { brand } from '../../../config/brand';

const product = brand.products.find(p => p.slug === "revenue-leak-audit-template")!;
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title="Revenue Leak Audit Template | UHL Systems" description="Das komplette DIY-Audit-Framework. Excel + Notion Template mit vordefinierten Formeln, ROI-Rechner und Video-Walkthrough. Unser Bestseller." />
		<style>
			.hero-headline {
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.1;
				letter-spacing: -0.03em;
			}
			.section-heading {
				font-size: clamp(28px, 4vw, 44px);
				line-height: 1.15;
				letter-spacing: -0.02em;
			}
			.cta-primary {
				background-color: var(--color-accent);
				color: var(--color-bg);
				border-radius: 999px;
				padding: 16px 40px;
				font-weight: 600;
				font-size: 18px;
				transition: all 0.2s;
				display: inline-block;
			}
			.cta-primary:hover {
				box-shadow: 0 0 32px rgba(0, 255, 136, 0.35);
				color: var(--color-bg);
			}
			.content-width {
				max-width: 820px;
				margin: 0 auto;
			}
			.feature-item {
				display: flex;
				align-items: flex-start;
				gap: 14px;
			}
			.feature-icon {
				flex-shrink: 0;
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				background: rgba(0, 255, 136, 0.1);
				color: var(--color-accent);
				margin-top: 2px;
			}
			.faq-item {
				border-bottom: 1px solid var(--color-border);
				padding: 24px 0;
			}
			.faq-item:last-child {
				border-bottom: none;
			}
		</style>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Fuer wen ist das?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Das Revenue Leak Audit Template ist fuer Business-Inhaber, die ein professionelles Revenue-Audit selbst durchfuehren wollen. Perfekt fuer Coaches, SaaS-Gruender und Berater, die die Struktur eines bezahlten Audits wollen - ohne den Preis."
					}
				},
				{
					"@type": "Question",
					"name": "In welchem Format ist das Template?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Du bekommst eine Excel-Tabelle mit vordefinierten Formeln, ein Notion-Workspace-Template und einen 20-minuetigen Video-Walkthrough, der dir zeigt, wie du beides nutzt."
					}
				},
				{
					"@type": "Question",
					"name": "Brauche ich Vorkenntnisse?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Nein. Der Video-Walkthrough fuehrt dich durch jeden Schritt. Die Templates sind mit Formeln und Frameworks vorbereitet - du gibst nur deine Zahlen ein und das System macht die Analyse."
					}
				}
			]
		}
		</script>
	</head>
	<body>
		<Header />

		<!-- Breadcrumb -->
		<div class="px-6 pt-28 pb-4">
			<div class="content-width">
				<nav class="flex items-center gap-2 font-mono text-sm text-muted-dark">
					<a href="/de/shop" class="transition-colors hover:text-accent">Shop</a>
					<span>&rarr;</span>
					<span class="text-muted">Revenue Leak Audit Template</span>
				</nav>
			</div>
		</div>

		<!-- Hero -->
		<section class="px-6 pb-20 pt-8">
			<div class="content-width">
				<div class="mb-6 flex flex-wrap items-center gap-3">
					<span class="inline-block rounded-full bg-accent/10 px-4 py-1.5 font-mono text-[11px] tracking-wider text-accent uppercase">Digitaler Download - Sofort-Zugang</span>
					<span class="inline-block rounded-full bg-accent/15 px-4 py-1.5 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">Bestseller</span>
				</div>
				<h1 class="hero-headline fade-in font-display font-bold text-text">
					Revenue Leak Audit Template
				</h1>
				<p class="fade-in fade-in-delay-1 mt-6 max-w-2xl text-lg leading-relaxed text-muted">
					Das komplette DIY-Audit-Framework. Fuehre ein professionelles Revenue-Leak-Audit an deinem eigenen Business durch - mit vordefinierten Formeln, die dir genau zeigen, wo du Geld verlierst.
				</p>
				<div class="fade-in fade-in-delay-2 mt-10 flex flex-wrap items-center gap-5">
					<div class="flex items-center gap-3">
						<span class="font-display text-4xl font-bold text-text">&euro;147</span>
						<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">Bestseller</span>
					</div>
				</div>
				<div class="fade-in fade-in-delay-3 mt-8">
					<a href={product.checkoutUrl} class="cta-primary block w-full text-center">Jetzt kaufen - {product.price}</a>
				</div>
			</div>
		</section>

		<!-- What You Get -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Was du bekommst</h2>
				<div class="grid gap-6 sm:grid-cols-2">
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Excel + Notion Template</p>
							<p class="mt-1 text-sm text-muted">Arbeite im Tool deiner Wahl - beides ist enthalten</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Vordefinierte Formeln</p>
							<p class="mt-1 text-sm text-muted">Gib einfach deine Zahlen ein - das Template rechnet</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">7-Stationen-Analyse-Framework</p>
							<p class="mt-1 text-sm text-muted">Jede Station deines Revenue-Systems auditieren</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">ROI-Rechner</p>
							<p class="mt-1 text-sm text-muted">Sieh genau, wie viel Umsatz du zurueckholen kannst</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Priorisierungsmatrix</p>
							<p class="mt-1 text-sm text-muted">Fixes nach Impact vs. Aufwand ranken - fokussiere auf das Wichtige</p>
						</div>
					</div>
					<div class="feature-item">
						<div class="feature-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<p class="font-semibold text-text">Video-Walkthrough (20 Min)</p>
							<p class="mt-1 text-sm text-muted">Schau genau zu, wie du das Template Schritt fuer Schritt nutzt</p>
						</div>
					</div>
				</div>
				<p class="mt-8 font-mono text-sm text-muted-dark">Format: Excel + Notion + Video</p>
			</div>
		</section>

		<!-- Who This Is For -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-12 font-display font-bold text-text">Fuer wen ist das</h2>
				<div class="grid gap-8 sm:grid-cols-3">
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Coaches</p>
						<p class="text-[15px] text-muted">Du willst ein strukturiertes Audit deines Business durchfuehren, ohne einen Berater zu bezahlen - und die gleiche Ergebnisqualitaet bekommen.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">SaaS-Gruender</p>
						<p class="text-[15px] text-muted">Du brauchst ein datengetriebenes Framework, um herauszufinden, wo User abspringen und wo Umsatz in deinem System stecken bleibt.</p>
					</div>
					<div class="rounded-xl border border-border bg-bg2 p-6">
						<p class="mb-2 font-mono text-xs tracking-wider text-accent uppercase">Berater</p>
						<p class="text-[15px] text-muted">Du willst deinen eigenen Kunden Revenue-Audits anbieten - mit einem bewaehrten, professionellen Template.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- What Problem It Solves -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Welches Problem es loest</h2>
				<div class="space-y-6 text-[16px] leading-relaxed text-muted">
					<p>
						Du weisst, dass du Geld auf dem Tisch liegen laesst - aber du hast keine systematische Methode herauszufinden, wie viel oder wo. Bauchgefuehl und zufaellige Optimierung funktionieren nicht. Du brauchst ein Framework, das jede Stufe deines Revenue-Systems betrachtet, die Leaks quantifiziert und dir sagt, welche Fixes den hoechsten ROI haben.
					</p>
					<p>
						Das Revenue Leak Audit Template ist dieses Framework. Es fuehrt dich durch 7 Stationen deines Revenue-Systems - von Traffic-Akquise bis Lifetime Value - mit vordefinierten Formeln, die deine Leak-Groesse auf jeder Stufe berechnen. Der eingebaute ROI-Rechner zeigt dir, wie viel Umsatz du zurueckholen kannst, und die Priorisierungsmatrix sagt dir genau, wo du anfangen sollst.
					</p>
					<p>
						Das ist dasselbe Framework, das wir in unseren 2.5k+ Kunden-Audits verwenden. Der Unterschied? Du fuehrst es selbst durch, in deinem eigenen Tempo, fuer einen Bruchteil der Kosten. Der 20-minuetige Video-Walkthrough stellt sicher, dass du die gleiche Ergebnisqualitaet bekommst.
					</p>
				</div>
			</div>
		</section>

		<!-- Sample / Preview -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Das steckt drin</h2>
				<div class="rounded-xl border border-border bg-bg2 p-8">
					<ul class="space-y-4 text-[15px] text-muted">
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>7-Stationen Revenue-Audit - von Traffic bis LTV, jede Station bekommt ihren eigenen Analyse-Tab</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>Auto-berechnete Leak-Scores - gib deine Zahlen ein und das Template hebt deine groessten Leaks hervor</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>ROI-Projektions-Dashboard - sieh, wie viel Umsatz du durch die Behebung jedes Leaks zurueckgewinnen wuerdest</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="mt-1 text-accent">&#9656;</span>
							<span>20-Minuten Video-Walkthrough - schau genau zu, wie du das Template ausfuellst und die Ergebnisse interpretierst</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="border-t border-border px-6 py-20">
			<div class="content-width">
				<h2 class="section-heading mb-8 font-display font-bold text-text">Haeufig gestellte Fragen</h2>
				<div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Fuer wen ist das?</h3>
						<p class="text-[15px] text-muted">Das Revenue Leak Audit Template ist fuer Business-Inhaber, die ein professionelles Revenue-Audit selbst durchfuehren wollen. Perfekt fuer Coaches, SaaS-Gruender und Berater, die die Struktur eines bezahlten Audits wollen - ohne den Preis.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">In welchem Format ist das Template?</h3>
						<p class="text-[15px] text-muted">Du bekommst eine Excel-Tabelle mit vordefinierten Formeln, ein Notion-Workspace-Template und einen 20-minuetigen Video-Walkthrough, der dir zeigt, wie du beides nutzt.</p>
					</div>
					<div class="faq-item">
						<h3 class="mb-3 text-lg font-semibold text-text">Brauche ich Vorkenntnisse?</h3>
						<p class="text-[15px] text-muted">Nein. Der Video-Walkthrough fuehrt dich durch jeden Schritt. Die Templates sind mit Formeln und Frameworks vorbereitet - du gibst nur deine Zahlen ein und das System macht die Analyse.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Bottom -->
		<section class="border-t border-border px-6 py-24">
			<div class="content-width text-center">
				<div class="flex items-center justify-center gap-3 mb-6">
					<span class="font-display text-4xl font-bold text-text">&euro;147</span>
					<span class="rounded-full bg-accent/15 px-3 py-1 font-mono text-[11px] font-bold tracking-wider text-accent uppercase">Bestseller</span>
				</div>
				<a href={product.checkoutUrl} class="cta-primary block w-full text-center">Jetzt kaufen - {product.price}</a>
				</div>
		</section>


	<!-- Upsell -->
	<section class="border-t border-border px-6 py-16 bg-bg2">
		<div class="mx-auto max-w-3xl text-center">
			<p class="font-mono text-xs tracking-widest text-accent uppercase mb-3">Naechster Schritt</p>
			<h3 class="font-display text-xl font-bold text-text mb-3">
				Willst du das volle Bild?
			</h3>
			<p class="text-muted text-sm mb-6 max-w-md mx-auto">
				Der Strategy Call nimmt deine Revenue Leak Map und macht daraus einen priorisierten Aktionsplan - spezifisch fuer dein Business.
			</p>
			<a href={brand.strategyCall.checkoutUrl} class="cta-primary inline-flex items-center gap-2">
				Strategy Call buchen - €97
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
			<p class="mt-2 font-mono text-xs text-muted-dark">30 Min &nbsp;|&nbsp; €97 &nbsp;|&nbsp; Zahlung bei Buchung</p>
		</div>
	</section>

		<Footer />
	</body>
</html>
